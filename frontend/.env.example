# Dealix frontend environment variables.
# Copy to .env.local for local development.

# Backend API base URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Default actor name shown in the Approval Center.
NEXT_PUBLIC_APPROVAL_ACTOR=sami

# Optional demo API key for operational tools.
NEXT_PUBLIC_DEMO_API_KEY=

# Gate the SprintToolsPanel debug tools (set to 1 to enable).
NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=0

# Admin API key for the Ops Console (/api/v1/ops/*) endpoints, which are
# admin-key gated on the backend. The Ops Console is an internal operator
# tool — set this to one of the backend's ADMIN_API_KEYS values.
NEXT_PUBLIC_ADMIN_API_KEY=
