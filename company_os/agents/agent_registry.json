{
  "version": "1.0",
  "last_updated": "2026-06-03",
  "autonomy_levels": {
    "L1": "Observe — read and analyze only",
    "L2": "Advise — recommend, never execute",
    "L3": "Draft — prepare drafts for review",
    "L4": "Act with Approval — execute only after explicit founder approval",
    "L5": "Autonomous — internal sandbox actions only (internal reports)"
  },
  "hard_rules": [
    "Agents may generate.",
    "Agents may recommend.",
    "Agents may prepare.",
    "Agents may NOT externally send, call, price-change, contract, or start delivery without founder approval."
  ],
  "required_fields": [
    "workflow",
    "input_contract",
    "output_contract",
    "level",
    "quality_gate",
    "audit_log",
    "owner",
    "stop_rule"
  ],
  "agents": [
    {
      "id": "account_research",
      "name": "Account Research Agent",
      "level": "L1",
      "function": "Collect public account information and build account pack drafts",
      "reads": ["web/public data", "company_os/revenue/prospects.csv"],
      "writes": ["account_packs draft"],
      "forbidden": ["secrets", "private data", "external actions"],
      "workflow": "research_account",
      "input_contract": "company_name + public_domain",
      "output_contract": "account_pack_draft.json with sources cited",
      "quality_gate": "all claims sourced, no PII, no scraped private data",
      "audit_log": true,
      "owner": "founder",
      "stop_rule": "stop if data requires authentication or appears private",
      "can_send_external": false,
      "can_call": false,
      "can_change_price": false,
      "can_contract": false,
      "can_start_delivery": false,
      "requires_approval": false,
      "internal_only": false
    },
    {
      "id": "need_detection",
      "name": "Need Detection Agent",
      "level": "L2",
      "function": "Detect the business need from an account pack",
      "reads": ["account pack"],
      "writes": ["recommended_need"],
      "forbidden": ["external actions", "send"],
      "workflow": "detect_need",
      "input_contract": "account_pack.json",
      "output_contract": "recommended_need with confidence score",
      "quality_gate": "need clarity score >= 75 before surfacing",
      "audit_log": true,
      "owner": "founder",
      "stop_rule": "stop and flag if confidence < 60",
      "can_send_external": false,
      "can_call": false,
      "can_change_price": false,
      "can_contract": false,
      "can_start_delivery": false,
      "requires_approval": false,
      "internal_only": false
    },
    {
      "id": "system_router",
      "name": "System Router Agent",
      "level": "L2",
      "function": "Choose the right Dealix system for the detected need",
      "reads": ["catalog", "recommended_need"],
      "writes": ["recommendation"],
      "forbidden": ["pricing override", "external actions"],
      "workflow": "route_system",
      "input_contract": "recommended_need + system_catalog",
      "output_contract": "system recommendation + rationale",
      "quality_gate": "recommendation maps to a catalog system with a clear first sprint",
      "audit_log": true,
      "owner": "founder",
      "stop_rule": "stop if no catalog system fits the need",
      "can_send_external": false,
      "can_call": false,
      "can_change_price": false,
      "can_contract": false,
      "can_start_delivery": false,
      "requires_approval": false,
      "internal_only": false
    },
    {
      "id": "email_draft",
      "name": "Email Draft Agent",
      "level": "L3",
      "function": "Write the outreach email draft",
      "reads": ["need card"],
      "writes": ["email draft"],
      "forbidden": ["send", "automated sending"],
      "workflow": "draft_email",
      "input_contract": "need_card + account_pack",
      "output_contract": "email draft (subject + body) into approval_queue",
      "quality_gate": "no guaranteed claims, no fake Re/Fwd, unsubscribe-compatible, no PII leakage",
      "audit_log": true,
      "owner": "founder",
      "stop_rule": "never send; always route to approval_queue",
      "can_send_external": false,
      "can_call": false,
      "can_change_price": false,
      "can_contract": false,
      "can_start_delivery": false,
      "requires_approval": true,
      "internal_only": false
    },
    {
      "id": "call_brief",
      "name": "Call Brief Agent",
      "level": "L3",
      "function": "Prepare the caller brief",
      "reads": ["account pack"],
      "writes": ["call brief"],
      "forbidden": ["automated calls", "external actions"],
      "workflow": "prepare_call_brief",
      "input_contract": "account_pack + need_card",
      "output_contract": "call brief (talking points + objections)",
      "quality_gate": "no automated dialing, human caller only",
      "audit_log": true,
      "owner": "founder",
      "stop_rule": "never place automated calls",
      "can_send_external": false,
      "can_call": false,
      "can_change_price": false,
      "can_contract": false,
      "can_start_delivery": false,
      "requires_approval": true,
      "internal_only": false
    },
    {
      "id": "proposal",
      "name": "Proposal Agent",
      "level": "L3",
      "function": "Prepare a Mini Proposal draft",
      "reads": ["account pack"],
      "writes": ["proposal draft"],
      "forbidden": ["send", "contract", "pricing override"],
      "workflow": "prepare_proposal",
      "input_contract": "account_pack + approved_need + price_band",
      "output_contract": "Mini Proposal draft into approval_queue",
      "quality_gate": "price within approved band, no guaranteed ROI claims",
      "audit_log": true,
      "owner": "founder",
      "stop_rule": "never send or sign; never change price outside approved band",
      "can_send_external": false,
      "can_call": false,
      "can_change_price": false,
      "can_contract": false,
      "can_start_delivery": false,
      "requires_approval": true,
      "internal_only": false
    },
    {
      "id": "delivery",
      "name": "Delivery Agent",
      "level": "L4",
      "function": "Prepare the delivery tasks and checklist",
      "reads": ["won pipeline"],
      "writes": ["tasks/checklist"],
      "forbidden": ["start without inputs", "external actions"],
      "workflow": "prepare_delivery",
      "input_contract": "won_deal + signed_inputs + intake",
      "output_contract": "delivery task list + checklist",
      "quality_gate": "all required inputs present before any task is generated",
      "audit_log": true,
      "owner": "founder",
      "stop_rule": "do not start delivery without confirmed inputs and approval",
      "can_send_external": false,
      "can_call": false,
      "can_change_price": false,
      "can_contract": false,
      "can_start_delivery": false,
      "requires_approval": true,
      "internal_only": false
    },
    {
      "id": "founder_command",
      "name": "Founder Command Agent",
      "level": "L2",
      "function": "Raise the daily founder command and decisions queue",
      "reads": ["reports"],
      "writes": ["daily command"],
      "forbidden": ["execute decisions", "external actions"],
      "workflow": "build_daily_command",
      "input_contract": "daily reports + pipeline + scale state",
      "output_contract": "FOUNDER_WAR_ROOM_DAILY.md",
      "quality_gate": "decisions surfaced, never executed",
      "audit_log": true,
      "owner": "founder",
      "stop_rule": "never execute a decision; only surface it",
      "can_send_external": false,
      "can_call": false,
      "can_change_price": false,
      "can_contract": false,
      "can_start_delivery": false,
      "requires_approval": false,
      "internal_only": false
    },
    {
      "id": "internal_reporter",
      "name": "Internal Reporter Agent",
      "level": "L5",
      "function": "Generate internal-only reports inside the sandbox",
      "reads": ["internal reports", "company_os data"],
      "writes": ["reports/* (internal)"],
      "forbidden": ["external actions", "send", "client-facing output"],
      "workflow": "generate_internal_report",
      "input_contract": "internal company_os data",
      "output_contract": "internal report markdown",
      "quality_gate": "output stays inside repo, never leaves sandbox",
      "audit_log": true,
      "owner": "founder",
      "stop_rule": "never produce client-facing or external output",
      "can_send_external": false,
      "can_call": false,
      "can_change_price": false,
      "can_contract": false,
      "can_start_delivery": false,
      "requires_approval": false,
      "internal_only": true
    }
  ]
}
