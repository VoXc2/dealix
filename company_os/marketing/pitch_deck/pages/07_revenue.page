pageType: content
background:
  type: solid
  color: "$bgLight"
elements:
  - elementId: page-title
    elementType: text
    bounds: [60, 40, 900, 50]
    content:
      style: "$pageTitle"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>نموذج الإيرادات: Service-led SaaS</strong></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 95, 80, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: stage-1-bg
    elementType: shape
    bounds: [60, 120, 270, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: stage-1-num
    elementType: text
    bounds: [80, 130, 60, 40]
    content:
      fontSize: 28
      color: "$accent"
      fontFamily: "QuattrocentoSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>1</strong></p>

  - elementId: stage-1-title
    elementType: text
    bounds: [80, 175, 230, 30]
