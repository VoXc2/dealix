pageType: content
background:
  type: solid
  color: "$bgDark"
elements:
  - elementId: page-title
    elementType: text
    bounds: [60, 40, 900, 50]
    content:
      style: "$pageTitleLight"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>حوكمة AI: Human-in-the-Loop دائماً</strong></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 95, 80, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: flow-label
    elementType: text
    bounds: [60, 120, 600, 30]
    content:
      fontSize: 18
      color: "$textMuted"
      fontFamily: "QuattrocentoSans"
      align: [left, middle]
      wrap: false
      text: |
        <p>نموذج العمل: AI drafts → Human approves → System logs → Company learns</p>

  - elementId: flow-box-1
    elementType: shape
    bounds: [60, 170, 220, 50]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: flow-text-1
    elementType: text
    bounds: [60, 170, 220, 50]
    content:
      fontSize: 16
      color: "$textLight"
      fontFamily: "QuattrocentoSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>AI Drafts</strong></p>

  - elementId: flow-arrow-1
    elementType: shape
    bounds: [290, 190, 50, 0]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border:
      style: solid
      width: 2
      color: "$primary"

  - elementId: flow-box-2
    elementType: shape
    bounds: [350, 170, 220, 50]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: flow-text-2
    elementType: text
    bounds: [350, 170, 220, 50]
    content:
      fontSize: 16
      color: "$primaryDark"
      fontFamily: "QuattrocentoSans"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Human Approves</strong></p>

  - elementId: flow-arrow-2
    elementType: shape
    bounds: [580, 190, 50, 0]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border:
      style: solid
      width: 2
      color: "$primary"

  - elementId: flow-box-3
    elementType: shape
    bounds: [640, 170, 220, 50]
    shapeName: rect
    fill:
      type: solid
      color: "#15807Acc"

  - elementId: flow-text-3
