pageType: content
background:
  type: solid
  color: "$bgDark"
elements:
  - elementId: page-title
    elementType: text
    bounds: [60, 40, 900, 50]
    content:
      style: "$pageTitleLight"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>الحل: Revenue Intelligence Sprint</strong></p>

  - elementId: title-accent
    elementType: shape
    bounds: [60, 95, 80, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: subtitle
    elementType: text
    bounds: [60, 110, 800, 35]
    content:
      fontSize: 20
      color: "$textMuted"
      fontFamily: "QuattrocentoSans"
      align: [left, middle]
      wrap: false
      text: |
        <p>5 أيام تكشف وين تضيع فرصك وتعطيك خطة تشغيل واضحة</p>

  - elementId: card-1-bg
    elementType: shape
    bounds: [60, 170, 360, 230]
    shapeName: rect
    fill:
      type: solid
      color: "#0F2E2C"
    border:
      style: solid
      width: 1
      color: "#15807A30"

  - elementId: card-1-icon
    elementType: icon
    bounds: [85, 195, 36, 36]
    iconName: "fas:chart-line"
    fill:
      type: solid
      color: "$primary"

  - elementId: card-1-title
