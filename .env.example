# Dealix Environment Variables
#
# Copy this file to .env.local and fill in your own values.
# Never commit real secrets to the repository.

# ============================================================
# App / Server
# ============================================================
NODE_ENV=development
PORT=3000

# ============================================================
# Database (MySQL)
# ============================================================
DATABASE_URL=mysql://dealix:dealix_pass_2026@localhost:3306/dealix
DB_USER=dealix
DB_PASSWORD=dealix_pass_2026
DB_NAME=dealix
DB_PORT=3306
DB_ROOT_PASSWORD=dealix_root_2026

# ============================================================
# Auth / App (Kimi OAuth)
# ============================================================
APP_ID=
APP_SECRET=
KIMI_AUTH_URL=
KIMI_OPEN_URL=
OWNER_UNION_ID=

# Frontend OAuth
VITE_APP_ID=
VITE_KIMI_AUTH_URL=

# ============================================================
# Safety Defaults — DO NOT ENABLE in production without
# explicit founder approval and an override file.
# ============================================================
EXTERNAL_SEND_ENABLED=false
EMAIL_SEND_ENABLED=false
WHATSAPP_SEND_ENABLED=false
WHATSAPP_ALLOW_LIVE_SEND=false
SMS_SEND_ENABLED=false
OUTBOUND_MODE=draft_only
WHATSAPP_AGENT_MODE=dry_run

# ============================================================
# WhatsApp Cloud API (optional — only when ready to go live)
# ============================================================
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ============================================================
# Email (optional — only when ready to go live)
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@dealix.me

# ============================================================
# AWS / S3 (optional — only if using file uploads)
# ============================================================
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
