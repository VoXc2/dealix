# Dealix — Environment Variables Template
# انسخ هذا الملف إلى .env وعبّي القيم الحقيقية.
# NEVER commit .env with real values.

# ── Required for Production ────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# Secret key for signing (64-byte hex)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=CHANGE_ME_to_64_byte_hex

# Database (Railway/Render/Heroku auto-normalize postgres:// → postgresql+asyncpg://)
DATABASE_URL=postgresql://user:pass@host:5432/dealix

# Public URL (for Moyasar checkout callback)
APP_URL=https://dealix.sa

# ── Moyasar Payments ───────────────────────────────────────────
MOYASAR_SECRET_KEY=sk_live_REPLACE_ME
MOYASAR_WEBHOOK_SECRET=REPLACE_with_shared_secret_from_dashboard

# ── PostHog Analytics ──────────────────────────────────────────
POSTHOG_API_KEY=phc_REPLACE_ME
POSTHOG_HOST=https://us.i.posthog.com

# ── Calendly ───────────────────────────────────────────────────
CALENDLY_URL=https://calendly.com/sami-assiri11/dealix-demo
CALENDLY_WEBHOOK_SECRET=REPLACE_ME

# ── WhatsApp (Meta) ────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=REPLACE_ME
WHATSAPP_APP_SECRET=REPLACE_ME
WHATSAPP_ACCESS_TOKEN=REPLACE_ME

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=https://dealix.sa,https://www.dealix.sa,http://localhost:3000

# ── Security (optional but recommended) ────────────────────────
API_KEYS=REPLACE_with_comma_separated_keys
# Separate high-privilege key for /api/v1/admin/* endpoints (REQUIRED in production)
ADMIN_API_KEYS=REPLACE_with_admin_only_key

# ── Docker / local dev database credentials ────────────────────
# These are only used by docker-compose for local dev.
# Production uses the full DATABASE_URL / REDIS_URL / MONGODB_URI directly.
REDIS_PASSWORD=REPLACE_with_redis_password
MONGO_PASSWORD=REPLACE_with_mongo_password

# ── Observability (optional) ───────────────────────────────────
SENTRY_DSN=

# ──────────────────────────────────────────────────────────────────
# Lead machine — Provider chains (see docs/ops/LEAD_MACHINE_TOOLING.md)
# Each layer is additive: chains fall back gracefully when keys are absent.
# ──────────────────────────────────────────────────────────────────

# ── Layer 1 — LLM (pick at least one) ──────────────────────────
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Layer 2 — Web search (Google CSE primary, Tavily fallback) ─
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
TAVILY_API_KEY=

# ── Layer 2 — Local discovery (Saudi sectors via Google Places) ─
GOOGLE_MAPS_API_KEY=
SERPAPI_API_KEY=
APIFY_TOKEN=

# ── Layer 2 — Crawler (markdown extraction for prospect sites) ─
FIRECRAWL_API_KEY=

# ── Layer 2 — Email intelligence (PDPL-aware) ──────────────────
HUNTER_API_KEY=
ABSTRACT_API_KEY=

# ── Layer 2 — Tech detection (internal is free + always-on) ────
WAPPALYZER_API_KEY=

# ── Layer 3 — Daily Email Automation (Gmail OAuth, no password) ─
# See docs/ops/GMAIL_OAUTH_SETUP_CHECKLIST.md for the 8-step setup
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
GMAIL_LIST_UNSUBSCRIBE=
DAILY_EMAIL_LIMIT=50
EMAIL_BATCH_SIZE=10
EMAIL_BATCH_INTERVAL_MINUTES=90

# ── Layer 3 — WhatsApp Multi-Provider (smart fallback) ─────────
# Chain: Green API → Ultramsg → Fonnte → Meta Cloud
# Recommended: Green API for free dev tier (5-min QR setup)
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
FONNTE_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
WHATSAPP_MOCK_MODE=false
WHATSAPP_TEST_ALLOWLIST=

# ── Layer 3 — Channels ─────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_INBOUND_SECRET=
WHATSAPP_PROVIDER=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_PROVIDER_API_KEY=
WHATSAPP_PROVIDER_BASE_URL=
GOOGLE_LEAD_FORM_WEBHOOK_KEY=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# ──────────────────────────────────────────────────────────────────
# Commercial readiness — T0 / T1 / T2 integrations
# Every variable below is optional; the related feature 503s or no-ops
# until set. See docs/QA_REVIEW.md and the v2 plan for the chosen stack.
# ──────────────────────────────────────────────────────────────────

# ── International payments (Stripe) — T0 ───────────────────────
# Used by dealix/payments/stripe_client.py.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Customer support (Plain) — T0 ──────────────────────────────
# When unset, support tickets fall back to email-via-Resend.
PLAIN_API_KEY=
PLAIN_WORKSPACE_ID=
SUPPORT_INBOX_EMAIL=support@ai-company.sa

# ── Enterprise SSO (WorkOS) — T1 ───────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ── Authorization (Cerbos PDP) — T1 ────────────────────────────
# When set, core/authz.py calls Cerbos; otherwise falls back to static RBAC.
CERBOS_PDP_URL=
# Optional: refuse to fall back to static RBAC on Cerbos unreachable.
CERBOS_FAIL_CLOSED=

# ── LLM gateway (Portkey) — T1 ─────────────────────────────────
# Adds per-tenant cost attribution. Optional virtual keys map vendors.
PORTKEY_API_KEY=
PORTKEY_VIRTUAL_KEY_ANTHROPIC=
PORTKEY_VIRTUAL_KEY_OPENAI=
PORTKEY_VIRTUAL_KEY_GOOGLE=

# ── Notifications (Knock) — T1 ─────────────────────────────────
KNOCK_API_KEY=

# ── Secrets vault (Infisical) — T2 ─────────────────────────────
INFISICAL_TOKEN=
INFISICAL_PROJECT_ID=
INFISICAL_ENV=production
INFISICAL_SECRET_PATH=/

# ── Workflow engine (Inngest) — T2 ─────────────────────────────
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=
# Set INNGEST_DEV=1 to use the local dev runner (npx inngest-cli@latest dev)
INNGEST_DEV=

# ── Lead enrichment (Apollo + Clearbit + Wathq) — T2 ───────────
APOLLO_API_KEY=
CLEARBIT_API_KEY=
# Saudi commercial registry — request access via api.wathq.sa
WATHQ_API_KEY=

# ── Usage-based billing (Lago) — T2 ────────────────────────────
LAGO_API_KEY=
LAGO_BASE_URL=https://api.getlago.com

# ── Marketing automation (Loops) — T2 ──────────────────────────
LOOPS_API_KEY=

# ── Status page (BetterStack) — T0 ─────────────────────────────
# Heartbeat URL (per-monitor). The lifespan task pings this every 60s
# when set; BetterStack flips the status to "down" if pings stop.
BETTERSTACK_HEARTBEAT_URL=
BETTERSTACK_HEARTBEAT_INTERVAL_S=60
# Optional: public status page JSON (read by landing/trust/index.html
# via window.__DEALIX_BETTERSTACK_STATUS_URL__).
BETTERSTACK_STATUS_URL=

# ── Mintlify docs portal — T1 ──────────────────────────────────
# Used only by the docs build pipeline; nothing to set in app env.

# ── WorkOS organization mapping (per-tenant) ───────────────────
# Stored in TenantRecord.meta_json["workos_org_id"] at provisioning
# time; nothing to set here.

# ── Frontend public env ────────────────────────────────────────
# Read at build time by Next.js (frontend/).
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_BETTERSTACK_STATUS_URL=

# ──────────────────────────────────────────────────────────────────
# T3 — Best-tech-company stack additions
# ──────────────────────────────────────────────────────────────────

# ── LLM cost guardrails (core/llm/cost_guard.py) — T3b ────────
LLM_MAX_USD_PER_REQUEST=0.50
LLM_MAX_USD_PER_TENANT_DAY=25.00
LLM_DEGRADE_MODEL=claude-3-5-haiku-latest

# ── PostHog surveys (T3c — NPS dashboard) ─────────────────────
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# ── Tinybird embedded analytics (T3c) ─────────────────────────
TINYBIRD_TOKEN=
TINYBIRD_BASE_URL=https://api.tinybird.co

# ── PagerDuty (T3d) ───────────────────────────────────────────
PAGERDUTY_INTEGRATION_KEY=

# ── ZATCA cert lifecycle (T3e) ────────────────────────────────
ZATCA_COMPANY_NAME=
ZATCA_COMMON_NAME=Dealix
ZATCA_VAT_NUMBER=
ZATCA_CR_NUMBER=
ZATCA_API_BASE=https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal
ZATCA_OUTPUT_DIR=/etc/dealix/zatca

# ── Saudi business-hours middleware (T3e, opt-in) ─────────────
BUSINESS_HOURS_ENFORCE=

# ── Mintlify / Fern publishing (T1 + T3g) ─────────────────────
PYPI_TOKEN=
NPM_TOKEN=

# ── dbt analytics (T3c, optional) ─────────────────────────────
DBT_DUCKDB_PATH=./analytics/dbt/dealix.duckdb
DBT_BIGQUERY_PROJECT=
DBT_BIGQUERY_KEYFILE_JSON=

# ──────────────────────────────────────────────────────────────────
# T5 — AI excellence + Saudi sovereignty deep + platform power
# ──────────────────────────────────────────────────────────────────

# ── LiteLLM gateway (T5a) ─────────────────────────────────────
# Forward Anthropic/OpenAI/Gemini/Groq through a single proxy.
LITELLM_PROXY_URL=

# ── RAG embeddings + rerank (T5b) ─────────────────────────────
VOYAGE_API_KEY=
COHERE_API_KEY=

# ── Voice channel (T5c) ───────────────────────────────────────
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_AR=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID_AR=
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_PHONE_NUMBER_ID=
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=Dealix

# ── Saudi national integrations (T5d) ─────────────────────────
NAFATH_API_BASE=https://api.nafath.sa/api/v1
NAFATH_API_KEY=
YAKEEN_API_BASE=https://api.elm.sa/api/v1
YAKEEN_API_KEY=
TAP_SECRET_KEY=
TAP_WEBHOOK_SECRET=
TABBY_SECRET_KEY=
TAMARA_API_TOKEN=
SALLA_CLIENT_ID=
SALLA_WEBHOOK_SECRET=
ZID_API_TOKEN=
ZID_WEBHOOK_SECRET=
SAMA_OB_CLIENT_ID=
SAMA_OB_HOST=

# ── Observability deep (T5e) ──────────────────────────────────
HYPERDX_API_KEY=
HYPERDX_OTLP_ENDPOINT=https://in-otel.hyperdx.io
LOGFIRE_TOKEN=
LOGFIRE_SERVICE=dealix-api
HIGHLIGHT_PROJECT_ID=
NEXT_PUBLIC_HIGHLIGHT_PROJECT_ID=

# ── Search + graph (T5f) ──────────────────────────────────────
MEILI_URL=
MEILI_API_KEY=
MEMGRAPH_URL=
MEMGRAPH_HOST=127.0.0.1
MEMGRAPH_PORT=7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# ── Platform polish (T5g) ─────────────────────────────────────
GRAPHQL_ENABLED=
SNYK_TOKEN=
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET=
EXPO_PUBLIC_API_BASE=

# ── MCP server (T5a) ──────────────────────────────────────────
# When customers add Dealix as an MCP server in Claude Desktop, they
# paste a tenant API key here on their side.
DEALIX_API_KEY=
MCP_SSE_PORT=

# ── WhatsApp template overrides (T4e wiring) ──────────────────
WHATSAPP_TEMPLATE_PROPOSAL_FOLLOWUP=
WHATSAPP_TEMPLATE_MEETING_CONFIRMATION=
WHATSAPP_TEMPLATE_PAYMENT_REMINDER=
WHATSAPP_TEMPLATE_TRIAL_EXPIRING=

