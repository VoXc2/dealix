# ═══════════════════════════════════════════════════════════════
# Dealix — Root .env example
# انسخ هذا الملف إلى .env ثم عدّل القيم
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Database ───
POSTGRES_DB=dealix
POSTGRES_USER=dealix
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432

# ─── Redis ───
REDIS_PORT=6379

# ─── Backend ───
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://dealix:change-me-in-production@db:5432/dealix
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-min-32-chars-in-production
DEALIX_INTERNAL_API_TOKEN=change-me-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── AI / LLM Keys ───
GROQ_API_KEY=gsk_your_key_here
OPENAI_API_KEY=sk_your_key_here

# ─── WhatsApp Business API ───
WHATSAPP_ACCESS_TOKEN=your_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_id_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=dealix_webhook_verify

# ─── Frontend ───
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# ─── Production-only ───
# SENTRY_DSN=https://...
# S3_ENDPOINT=https://...
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
