# Dealix — Environment Variables Template
# انسخ هذا الملف إلى .env وعبّي القيم الحقيقية.
# NEVER commit .env with real values.
#
# ─── السياسة (Policy) ───
#  • [REQUIRED]  = لا يقلع الإنتاج بدونها — _validate_production_secrets يفشل
#  • [REVENUE]   = مطلوب لتدفق الدفع (Moyasar)
#  • [OPTIONAL]  = layer إضافي — التشغيل يتفاوت بدونها لكن لا يكسر
#
# للـ onboarding التفاعلي: bash scripts/first_setup.sh
# للتحقق: make doctor  (يشغل scripts/check_env_contract.py)

# ── [REQUIRED] Core Production ─────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# Secret key for signing (64-byte hex)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=CHANGE_ME_to_64_byte_hex

# Database (Railway/Render/Heroku auto-normalize postgres:// → postgresql+asyncpg://)
DATABASE_URL=postgresql://user:pass@host:5432/dealix

# Public URL (for Moyasar checkout callback)
APP_URL=https://dealix.sa

# ── [REVENUE] Moyasar Payments ─────────────────────────────────
MOYASAR_SECRET_KEY=sk_live_REPLACE_ME
MOYASAR_WEBHOOK_SECRET=REPLACE_with_shared_secret_from_dashboard

# ── PostHog Analytics ──────────────────────────────────────────
POSTHOG_API_KEY=phc_REPLACE_ME
POSTHOG_HOST=https://us.i.posthog.com

# ── Calendly ───────────────────────────────────────────────────
CALENDLY_URL=https://calendly.com/sami-assiri11/dealix-demo
CALENDLY_WEBHOOK_SECRET=REPLACE_ME

# ── WhatsApp (Meta) ────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=REPLACE_ME
WHATSAPP_APP_SECRET=REPLACE_ME
WHATSAPP_ACCESS_TOKEN=REPLACE_ME

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=https://dealix.sa,https://www.dealix.sa,http://localhost:3000

# ── Security ───────────────────────────────────────────────────
API_KEYS=REPLACE_with_comma_separated_keys
# Separate high-privilege key for /api/v1/admin/* endpoints (REQUIRED in production)
ADMIN_API_KEYS=REPLACE_with_admin_only_key
# Optional alias used by some scripts (same value as first ADMIN_API_KEYS entry)
DEALIX_ADMIN_API_KEY=

# ── Docker / local dev database credentials ────────────────────
# These are only used by docker-compose for local dev.
# Production uses the full DATABASE_URL / REDIS_URL / MONGODB_URI directly.
REDIS_PASSWORD=REPLACE_with_redis_password
MONGO_PASSWORD=REPLACE_with_mongo_password

# ── [OPTIONAL] Observability ───────────────────────────────────
# CEO Master Plan P0: set on Railway API for production trust close
# Verify: python scripts/ceo_production_trust_bundle.py
SENTRY_DSN=

# ──────────────────────────────────────────────────────────────────
# Lead machine — Provider chains (see docs/ops/LEAD_MACHINE_TOOLING.md)
# Each layer is additive: chains fall back gracefully when keys are absent.
# ──────────────────────────────────────────────────────────────────

# ── [OPTIONAL] Layer 1 — LLM (pick at least one for live AI) ───
GROQ_API_KEY=
ANTHROPIC_API_KEY=
# Hermes Agents — Anthropic-native multi-agent system
# HERMES_API_KEY falls back to ANTHROPIC_API_KEY if not set
HERMES_API_KEY=
HERMES_MODEL=claude-opus-4-8
HERMES_FAST_MODEL=claude-haiku-4-5-20251001
HERMES_MAX_TOOL_ROUNDS=20
HERMES_LOOP_INTERVAL_SECONDS=300
HERMES_COST_BUDGET_USD=5.0
# ── [OPTIONAL] MiniMax (secondary LLM — high-volume daily tasks, bilingual) ──
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_DAILY_OUTREACH_ENABLED=true
MINIMAX_OUTREACH_MAX_PER_DAY=20
OPENAI_API_KEY=

# ── Layer 2 — Web search (Google CSE primary, Tavily fallback) ─
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
TAVILY_API_KEY=

# ── Layer 2 — Local discovery (Saudi sectors via Google Places) ─
GOOGLE_MAPS_API_KEY=
SERPAPI_API_KEY=
APIFY_TOKEN=

# ── Layer 2 — Crawler (markdown extraction for prospect sites) ─
FIRECRAWL_API_KEY=

# ── Layer 2 — Email intelligence (PDPL-aware) ──────────────────
HUNTER_API_KEY=
ABSTRACT_API_KEY=

# ── Layer 2 — Tech detection (internal is free + always-on) ────
WAPPALYZER_API_KEY=

# ── Layer 3 — Daily Email Automation (Gmail OAuth, no password) ─
# See docs/ops/GMAIL_OAUTH_SETUP_CHECKLIST.md for the 8-step setup
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
GMAIL_LIST_UNSUBSCRIBE=
DAILY_EMAIL_LIMIT=50
EMAIL_BATCH_SIZE=10
EMAIL_BATCH_INTERVAL_MINUTES=90

# ── Layer 3 — WhatsApp Multi-Provider (smart fallback) ─────────
# Chain: Green API → Ultramsg → Fonnte → Meta Cloud
# Recommended: Green API for free dev tier (5-min QR setup)
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
FONNTE_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
WHATSAPP_MOCK_MODE=false
WHATSAPP_TEST_ALLOWLIST=

# ── Layer 3 — Channels ─────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_INBOUND_SECRET=
WHATSAPP_PROVIDER=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_PROVIDER_API_KEY=
WHATSAPP_PROVIDER_BASE_URL=
GOOGLE_LEAD_FORM_WEBHOOK_KEY=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# ── Frontend — Services hub demo (optional) ────────────────────
# NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=1
# NEXT_PUBLIC_DEMO_API_KEY=when API_KEYS is set, use a valid key for browser demos
NEXT_PUBLIC_API_URL=https://api.dealix.me
# Recommended: proxy privileged Dealix operations through the Next.js server.
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=1
# Server-only: optional shared secret for /api/dealix-proxy when JWT unavailable (dev automation)
DEALIX_OPS_PROXY_SECRET=

# ── Persistence cutover (optional; engineering_cutover_policy.yaml applies) ─
# VALUE_LEDGER_BACKEND=jsonl|postgres|dual
# PROOF_LEDGER_BACKEND=file|postgres|dual
# DEALIX_OPERATIONAL_STREAM_BACKEND=off|postgres|dual
# DEALIX_VALUE_LEDGER_SYNC_DATABASE_URL=postgresql+psycopg://...
# DEALIX_OPERATIONAL_STREAM_SYNC_DATABASE_URL=postgresql+psycopg://...
# OTEL_CONTRACT_TRACE_EXPORT=false

# ── Wave 1 Postgres-first stores (optional — default in-memory) ─
# DEALIX_APPROVAL_STORE_BACKEND=postgres
# DEALIX_AUTOPILOT_STORE_BACKEND=postgres
# DEALIX_AGENT_REGISTRY_PATH=data/agent_registry.json

# ── Railway launch (API + FE + GitHub Actions) ─────────────────
# GitHub Actions: daily-revenue-machine + founder-commercial-daily + official-launch-verify
DEALIX_API_BASE=https://api.dealix.me
DEALIX_API_KEY=

# ── Executive readiness (shell — not env vars) ─────────────────
# bash scripts/run_ceo_one_session_readiness.sh
# See docs/transformation/CEO_ONE_SESSION_MASTER_PLAN_AR.md
# Official launch: bash scripts/official_launch_verify.sh · bootstrap: bash scripts/railway_prod_bootstrap.sh
# Full plan orchestrator: bash scripts/launch_execution_railway.sh
