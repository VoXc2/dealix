# ═══════════════════════════════════════════════════════════════
# Dealix — Root .env example
# انسخ هذا الملف إلى .env ثم عدّل القيم
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Port policy ───
# On servers that also run `dealix-api.service` (systemd) or a host Postgres/
# Redis, the defaults below WILL collide. Either stop the host services first
# or override the *_PORT variables to free ports (e.g. BACKEND_PORT=8001,
# REDIS_PORT=6380, POSTGRES_PORT=5433). See
# docs/project-merge-ai-company-saudi.md §7 for the single-runtime rule.

# ─── Database ───
POSTGRES_DB=dealix
POSTGRES_USER=dealix
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432

# ─── Redis ───
REDIS_PORT=6379

# ─── Backend ───
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://dealix:change-me-in-production@db:5432/dealix
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-min-32-chars-in-production
DEALIX_INTERNAL_API_TOKEN=change-me-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── AI / LLM Keys ───
GROQ_API_KEY=gsk_your_key_here
OPENAI_API_KEY=sk_your_key_here

# ─── Local AI (Ollama, on-prem) ───
# Set ENABLED=1 only after `scripts/local-ai/install_local_ai.sh` has pulled at
# least one model. Leave model overrides blank to use the tier-auto default.
LOCAL_LLM_ENABLED=0
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_DEFAULT_MODEL=
LOCAL_LLM_ROUTER_MODEL=
LOCAL_LLM_CODER_MODEL=
LOCAL_LLM_REASONER_MODEL=
LOCAL_LLM_TIMEOUT_S=120
LOCAL_LLM_RETRIES=2
# Override auto tier detection: nano | small | balanced | performance
LOCAL_LLM_FORCE_TIER=

# ─── WhatsApp Business API ───
WHATSAPP_ACCESS_TOKEN=your_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_id_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=dealix_webhook_verify

# ─── Frontend ───
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# ─── Production-only ───
# SENTRY_DSN=https://...
# S3_ENDPOINT=https://...
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
