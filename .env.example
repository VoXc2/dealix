# ============================================
# DEALIX - متغيرات البيئة
# ============================================

# --- التطبيق ---
APP_NAME=Dealix
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- قاعدة البيانات ---
DATABASE_URL=postgresql+asyncpg://dealix:dealix123@localhost:5432/dealix
DATABASE_URL_SYNC=postgresql://dealix:dealix123@localhost:5432/dealix

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT ---
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- SMTP ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@dealix.sa
SMTP_PASSWORD=change-me
SMTP_FROM_NAME=Dealix
SMTP_FROM_EMAIL=noreply@dealix.sa

# --- Twilio / SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- AI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Stripe / الدفع ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=

# --- السوق السعودي ---
DEFAULT_CURRENCY=SAR
DEFAULT_LOCALE=ar_SA
DEFAULT_TIMEZONE=Asia/Riyadh
