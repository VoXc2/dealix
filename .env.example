# ═══════════════════════════════════════════════════════════════════════════
# 🔐 AI Company Saudi Arabia — Environment Variables Template
# نموذج متغيرات البيئة — شركة AI السعودية
# ═══════════════════════════════════════════════════════════════════════════
# USAGE: cp .env.example .env   then fill in real values
# الاستخدام: انسخ هذا الملف إلى .env ثم املأ القيم الحقيقية
# ⚠️  NEVER COMMIT .env  |  لا ترفع ملف .env أبداً
# ═══════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# 🏢 Application Settings | إعدادات التطبيق
# ──────────────────────────────────────────────────────────────
APP_NAME="AI Company Saudi Arabia"
APP_ENV=development                # development | staging | production
APP_VERSION=2.1.0
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=Asia/Riyadh
APP_DEFAULT_LOCALE=ar
APP_DEFAULT_CURRENCY=SAR
APP_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Secret for JWT / session signing | سر التوقيع
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=change-me-to-a-long-random-string

# CORS allowed origins (comma-separated) | النطاقات المسموح بها
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ──────────────────────────────────────────────────────────────
# 🧠 LLM Providers | مزودو النماذج اللغوية
# ──────────────────────────────────────────────────────────────

# Anthropic Claude — reasoning, proposals, copy | المنطق والعروض
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT=60

# DeepSeek — code, implementation | الكود والتنفيذ
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# GLM (Z.ai) — Arabic/Chinese, bulk | العربية والصينية والمهام الكثيرة
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4

# Google Gemini — research, multimodal | البحث والتحليل متعدد الوسائط
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Groq (Llama 3.3 70B) — fast classification | التصنيف السريع
GROQ_API_KEY=
GROQ_API_KEY_ALT=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenAI (fallback) | احتياطي
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────────
# 💾 Databases | قواعد البيانات
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ai_user:ai_password@localhost:5432/ai_company
REDIS_URL=redis://localhost:6379/0
MONGODB_URI=mongodb://localhost:27017/ai_company

# ──────────────────────────────────────────────────────────────
# 📱 WhatsApp Business Cloud API (Meta) | واتساب للأعمال
# ──────────────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ──────────────────────────────────────────────────────────────
# 📧 Email (Resend / SendGrid) | البريد الإلكتروني
# ──────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend              # resend | sendgrid | smtp
EMAIL_FROM=noreply@ai-company.sa
EMAIL_FROM_NAME="AI Company Saudi"
RESEND_API_KEY=
SENDGRID_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# ──────────────────────────────────────────────────────────────
# 📅 Calendar (Google + Calendly) | التقويم
# ──────────────────────────────────────────────────────────────
GOOGLE_CALENDAR_CREDENTIALS_FILE=
GOOGLE_CALENDAR_ID=primary
CALENDLY_API_TOKEN=
CALENDLY_USER_URI=

# ──────────────────────────────────────────────────────────────
# 🤝 HubSpot CRM | إدارة علاقات العملاء
# ──────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# ──────────────────────────────────────────────────────────────
# 🔄 Automation | الأتمتة
# ──────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_ENCRYPTION_KEY=

# ──────────────────────────────────────────────────────────────
# 📊 Observability | المراقبة والتتبع
# ──────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=

# ──────────────────────────────────────────────────────────────
# 🌐 Other Services | خدمات أخرى
# ──────────────────────────────────────────────────────────────
CLICKBANK_API_KEY=
HIX_AI_API_KEY=

# ──────────────────────────────────────────────────────────────
# 💰 Business Config | إعدادات العمل
# ──────────────────────────────────────────────────────────────
# Pricing tiers in SAR | الأسعار بالريال السعودي
PRICING_SA_SETUP_MIN=12000
PRICING_SA_SETUP_MAX=40000
PRICING_SA_RETAINER_MIN=3000
PRICING_SA_RETAINER_MAX=12000

PRICING_GCC_SETUP_MIN=15000
PRICING_GCC_SETUP_MAX=50000
PRICING_GCC_RETAINER_MIN=4000
PRICING_GCC_RETAINER_MAX=15000

PRICING_GLOBAL_SETUP_MIN_USD=3000
PRICING_GLOBAL_SETUP_MAX_USD=10000
PRICING_GLOBAL_RETAINER_MIN_USD=800
PRICING_GLOBAL_RETAINER_MAX_USD=3000
