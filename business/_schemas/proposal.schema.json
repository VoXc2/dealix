{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dealix Proposal",
  "type": "object",
  "required": ["id", "accountId", "offer", "status", "createdAt"],
  "properties": {
    "id": {"type": "string"},
    "accountId": {"type": "string"},
    "offer": {"type": "string"},
    "lang": {"type": "string", "enum": ["ar", "en", "both"]},
    "timeline": {"type": "string"},
    "setupPrice": {"type": "integer", "minimum": 0},
    "monthlyPrice": {"type": "integer", "minimum": 0},
    "status": {"type": "string", "enum": ["draft", "sent", "accepted", "rejected"]},
    "createdAt": {"type": "string", "format": "date"},
    "sentAt": {"type": "string", "format": "date"}
  }
}
