# Wave 8 — Customer Credential Example Template
# Copy this to .env and fill in real values.
# NEVER commit .env with real values. All real values go in Railway Dashboard.
# Policy: PRESENT/MISSING/OPTIONAL/BLOCKED_BY_POLICY/DEMO_FALLBACK

# ── Core (Required for Production) ──────────────────────────────────────────
APP_SECRET_KEY=CHANGE_ME_64_byte_hex
DATABASE_URL=postgresql://user:pass@host:5432/dealix
ENVIRONMENT=production
LOG_LEVEL=INFO
APP_URL=https://dealix.sa

# ── Payments (BLOCKED_BY_POLICY — NO_LIVE_CHARGE) ───────────────────────────
# DO NOT configure until founder approves live charge activation
# MOYASAR_SECRET_KEY=BLOCKED_BY_POLICY
# MOYASAR_WEBHOOK_SECRET=BLOCKED_BY_POLICY

# ── Calendly / Cal.com ───────────────────────────────────────────────────────
CALENDLY_URL=https://calendly.com/your-name/dealix-demo
CALENDLY_WEBHOOK_SECRET=OPTIONAL_REPLACE_ME

# ── WhatsApp Business (OPTIONAL — manual personal WA is safe default) ────────
WHATSAPP_VERIFY_TOKEN=REPLACE_ME
WHATSAPP_APP_SECRET=REPLACE_ME
WHATSAPP_ACCESS_TOKEN=REPLACE_ME
WHATSAPP_PHONE_NUMBER_ID=REPLACE_ME

# ── LLM Providers (at least one required) ────────────────────────────────────
ANTHROPIC_API_KEY=OPTIONAL_sk-ant-...
OPENAI_API_KEY=OPTIONAL_sk-...
GROQ_API_KEY=OPTIONAL

# ── Observability (all optional) ─────────────────────────────────────────────
LANGFUSE_SECRET_KEY=OPTIONAL_sk-lf-...
LANGFUSE_PUBLIC_KEY=OPTIONAL_pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=OPTIONAL
POSTHOG_API_KEY=OPTIONAL_phc_...
POSTHOG_HOST=https://us.i.posthog.com
OTEL_EXPORTER_OTLP_ENDPOINT=OPTIONAL
OTEL_SERVICE_NAME=dealix

# ── Email (optional for transactional email) ─────────────────────────────────
RESEND_API_KEY=OPTIONAL_re_...
RESEND_FROM_EMAIL=noreply@dealix.sa

# ── CRM (optional per customer) ──────────────────────────────────────────────
HUBSPOT_API_KEY=OPTIONAL

# ── Internal notifications (optional) ────────────────────────────────────────
SLACK_BOT_TOKEN=OPTIONAL_xoxb-...
SLACK_CHANNEL_ID=OPTIONAL

# ── Google APIs (optional per customer) ──────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=OPTIONAL_base64_encoded_json

# ── Security ─────────────────────────────────────────────────────────────────
API_KEYS=REPLACE_with_comma_separated_keys
ADMIN_API_KEYS=REPLACE_with_admin_only_key
CORS_ORIGINS=https://dealix.sa,http://localhost:3000

# ── Database auth (local dev only) ───────────────────────────────────────────
REDIS_PASSWORD=REPLACE_with_redis_password
MONGO_PASSWORD=REPLACE_with_mongo_password
