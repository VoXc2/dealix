  "signature_policy": {
    "stages": [
      "diagnostic_complete",
      "proposal_sent",
      "risk_review_passed",
      "executive_alignment",
      "contract_ready"
    ],
    "ask_signature_when": [
      "stage in [executive_alignment, contract_ready]",
      "buyer_commitment >= medium",
      "proof_level >= L3",
      "risk_status != high",
      "governance_contract_accepted = true"
    ],
    "do_not_ask_if": [
      "proof_level <= L1",
      "decision_owner missing",
      "unresolved critical compliance blocker"
    ],
    "if_not_signed_within_days": {
      "3": "send executive recap with quantified KPI impact",
      "7": "run objection-handling call with decision owner",
      "14": "offer phased pilot scope with strict success criteria"
    }
  },
