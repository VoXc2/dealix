# Dealix production Docker environment template
# Copy to .env.prod on the server and fill real values there. Do not commit .env.prod.

# Domains
DEALIX_DOMAIN=dealix.me
DEALIX_API_DOMAIN=api.dealix.me
ACME_EMAIL=admin@dealix.me
NEXT_PUBLIC_SITE_URL=https://dealix.me
NEXT_PUBLIC_API_URL=https://api.dealix.me
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=1

# Image/build
IMAGE_TAG=latest
GIT_SHA=local

# API runtime
APP_ENV=production
ENVIRONMENT=production
LOG_LEVEL=INFO
APP_SECRET_KEY=CHANGE_ME_64_BYTE_HEX
JWT_SECRET_KEY=CHANGE_ME_64_BYTE_HEX
API_KEYS=CHANGE_ME_PRIVATE_API_KEY
ADMIN_API_KEYS=CHANGE_ME_ADMIN_API_KEY
DEALIX_ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY
APP_URL=https://dealix.me
CORS_ORIGINS=https://dealix.me,https://www.dealix.me,https://api.dealix.me

# Database
POSTGRES_USER=dealix
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=dealix
PGBOUNCER_MAX_CLIENT_CONN=300
PGBOUNCER_DEFAULT_POOL_SIZE=30

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_MAXMEMORY=512mb

# Optional observability
SENTRY_DSN=
OTEL_SERVICE_NAME=dealix

# Optional providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
TAVILY_API_KEY=
GOOGLE_MAPS_API_KEY=
SERPAPI_API_KEY=
APIFY_TOKEN=
FIRECRAWL_API_KEY=
HUNTER_API_KEY=
ABSTRACT_API_KEY=

# Optional channels
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
SENDGRID_API_KEY=
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
FONNTE_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
WHATSAPP_MOCK_MODE=false
WHATSAPP_TEST_ALLOWLIST=

# Optional payments
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=
