{
  "title": "Dealix — Durable workflows (Inngest)",
  "uid": "dealix-inngest",
  "tags": ["dealix", "inngest"],
  "schemaVersion": 39,
  "timezone": "Asia/Riyadh",
  "panels": [
    {
      "title": "Function runs / hour",
      "type": "timeseries",
      "datasource": "Inngest",
      "targets": [
        { "expr": "sum by (function_id) (rate(inngest_function_runs_total[5m]))" }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "title": "Failures / hour",
      "type": "timeseries",
      "datasource": "Inngest",
      "targets": [
        { "expr": "sum by (function_id) (rate(inngest_function_failures_total[5m]))" }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "title": "Step duration p95 (ms)",
      "type": "timeseries",
      "datasource": "Inngest",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le,function_id) (rate(inngest_step_duration_seconds_bucket[5m]))) * 1000"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 }
    }
  ]
}
