<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>You're invited to {{ tenant_name }} on Dealix</title>
</head>
<body style="font-family: Inter, system-ui, sans-serif; background:#f7f8fb; color:#0a0e1a; padding:24px;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;">
    <tr><td>
      <h1 style="margin:0 0 16px 0;font-size:22px;">Hi {{ recipient_name }},</h1>
      <p><strong>{{ inviter_name }}</strong> invited you to join <strong>{{ tenant_name }}</strong> on Dealix.</p>
      <p>Date: {{ gregorian_date }} ({{ hijri_date }} AH).</p>
      <p><a href="{{ invite_url }}" style="display:inline-block;background:#10b981;color:#fff;padding:12px 20px;border-radius:8px;text-decoration:none;font-weight:600;">Accept invitation</a></p>
      <p style="font-size:12px;color:#5a627a;">This link expires in 72 hours.</p>
      <hr style="border:none;border-top:1px solid #eee;margin:24px 0;" />
      <p style="font-size:12px;color:#5a627a;">
        Automated message from Dealix. To unsubscribe, reply STOP or visit the
        <a href="{{ unsubscribe_url }}">unsubscribe link</a>.
      </p>
    </td></tr>
  </table>
</body>
</html>
