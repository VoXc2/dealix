<!doctype html>
<html lang="en">
<head><meta charset="utf-8" /><title>New Dealix invoice</title></head>
<body style="font-family:Inter,system-ui,sans-serif;background:#f7f8fb;padding:24px;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;">
    <tr><td>
      <h1 style="margin:0 0 16px 0;">New invoice</h1>
      <p>Hi {{ recipient_name }},</p>
      <p>Amount: <strong>{{ amount_sar }} SAR</strong> ({{ amount_usd }} USD).</p>
      <p>Issued: {{ issued_at_en }} / {{ issued_at_hijri }} AH.</p>
      <p>ZATCA-cleared. Download the PDF + QR below.</p>
      <p><a href="{{ invoice_url }}" style="display:inline-block;background:#10b981;color:#fff;padding:12px 20px;border-radius:8px;text-decoration:none;">Download invoice</a></p>
      <p style="font-size:12px;color:#5a627a;">Billing questions: <a href="mailto:billing@ai-company.sa">billing@ai-company.sa</a>.</p>
    </td></tr>
  </table>
</body>
</html>
