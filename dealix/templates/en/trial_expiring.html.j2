<!doctype html>
<html lang="en">
<head><meta charset="utf-8" /><title>Your Dealix trial ends in 3 days</title></head>
<body style="font-family:Inter,system-ui,sans-serif;background:#f7f8fb;padding:24px;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;">
    <tr><td>
      <h1 style="margin:0 0 16px 0;">Hi {{ recipient_name }},</h1>
      <p>Your free Dealix trial ends in <strong>{{ days_left }}</strong> days (on {{ expires_at_en }} / {{ expires_at_hijri }} AH).</p>
      <p>In 14 days we captured for you:</p>
      <ul>
        <li>{{ leads_count }} leads</li>
        <li>{{ deals_open }} deals in flight</li>
        <li>{{ tickets_handled }} support tickets</li>
      </ul>
      <p><a href="{{ upgrade_url }}" style="display:inline-block;background:#10b981;color:#fff;padding:12px 20px;border-radius:8px;text-decoration:none;font-weight:600;">Upgrade in SAR</a></p>
      <p style="font-size:12px;color:#5a627a;">To unsubscribe, reply STOP or visit the <a href="{{ unsubscribe_url }}">unsubscribe link</a>.</p>
    </td></tr>
  </table>
</body>
</html>
