{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/cash_priority_score.schema.json",
  "title": "Dealix Cash Priority Score",
  "description": "Finance lens on an account: how quickly and profitably the opportunity can turn into cash. Score out of 100 from five weighted dimensions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_id",
    "company_name",
    "recommended_system",
    "expected_starter_price_sar",
    "delivery_complexity",
    "estimated_delivery_hours",
    "gross_margin_hint",
    "upsell_potential",
    "cash_priority_score",
    "breakdown",
    "generated_at"
  ],
  "properties": {
    "pack_id": { "type": "string", "pattern": "^AP-[0-9]{6}$" },
    "company_name": { "type": "string" },
    "recommended_system": { "type": "string" },
    "expected_starter_price_sar": { "type": "integer", "minimum": 1 },
    "delivery_complexity": { "type": "string", "enum": ["low", "medium", "high"] },
    "estimated_delivery_hours": { "type": "number", "minimum": 0 },
    "gross_margin_hint": { "type": "string" },
    "upsell_potential": { "type": "string", "enum": ["low", "medium", "high"] },
    "cash_priority_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "breakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ability_to_pay", "urgency", "ease_of_delivery", "upsell_potential", "contact_availability"],
      "properties": {
        "ability_to_pay": { "type": "integer", "minimum": 0, "maximum": 25 },
        "urgency": { "type": "integer", "minimum": 0, "maximum": 25 },
        "ease_of_delivery": { "type": "integer", "minimum": 0, "maximum": 20 },
        "upsell_potential": { "type": "integer", "minimum": 0, "maximum": 15 },
        "contact_availability": { "type": "integer", "minimum": 0, "maximum": 15 }
      }
    },
    "generated_at": { "type": "string" }
  }
}
