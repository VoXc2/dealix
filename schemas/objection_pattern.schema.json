{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/objection_pattern.schema.json",
  "title": "Objection Pattern",
  "description": "Anonymized objection record with frequency band, root cause, response playbook variants, and escalation path. No PII.",
  "type": "object",
  "required": [
    "objection",
    "sector",
    "frequency_band",
    "root_cause",
    "response_playbook",
    "proof_needed",
    "escalation_path",
    "evidence_level"
  ],
  "properties": {
    "objection": {
      "type": "string",
      "enum": [
        "too_expensive",
        "no_time",
        "we_already_have_vendor",
        "need_to_think",
        "send_proposal",
        "not_the_right_time",
        "not_relevant",
        "send_to_procurement",
        "we_tried_ai",
        "privacy_concerns",
        "no_budget",
        "internal_team"
      ]
    },
    "objection_label_ar": {
      "type": "string",
      "description": "Arabic label of the stated objection."
    },
    "sector": {
      "type": "string",
      "enum": [
        "industrial",
        "healthcare",
        "retail",
        "professional_services",
        "real_estate",
        "fnb",
        "logistics",
        "education",
        "government_related"
      ]
    },
    "frequency_band": {
      "type": "string",
      "enum": ["rare", "low", "medium", "high", "dominant"],
      "description": "How often this objection is observed in this sector."
    },
    "root_cause": {
      "type": "string",
      "description": "Hypothesis of the real blocker behind the stated objection."
    },
    "real_blocker_hypothesis": {
      "type": "string",
      "description": "Most-likely real blocker (different from stated objection)."
    },
    "response_playbook": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["variant_id", "language", "body"],
        "properties": {
          "variant_id": {"type": "string"},
          "language": {"type": "string", "enum": ["ar", "en", "mixed"]},
          "tone": {"type": "string", "enum": ["formal", "semi_formal", "consultative"]},
          "body": {"type": "string", "description": "Arabic-first response template, anonymized."}
        }
      }
    },
    "proof_needed": {
      "type": "string",
      "enum": ["L0_acknowledgement", "L1_insight", "L2_case", "L3_roi", "L4_audit", "L5_reference"],
      "description": "Minimum proof level to overcome this objection."
    },
    "escalation_path": {
      "type": "string",
      "description": "Where to escalate: founder review, partner, walk away, etc."
    },
    "detection_signal": {
      "type": "string",
      "description": "How to spot this objection early (keywords, behavior)."
    },
    "evidence_level": {
      "type": "string",
      "enum": ["assumption", "observed", "validated", "measured"]
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    }
  },
  "additionalProperties": false
}
