{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/case_study_permission.schema.json",
  "title": "Dealix Case Study Permission",
  "description": "Permission record for a case study mentioning a real client.",
  "type": "object",
  "required": ["permission_id", "client_id", "level", "decision"],
  "properties": {
    "permission_id": { "type": "string", "pattern": "^csp_[0-9_]+$" },
    "client_id": { "type": "string" },
    "client_name": { "type": "string" },
    "client_contact": { "type": "string" },
    "level": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4", "L5"] },
    "artifact_refs": { "type": "array", "items": { "type": "string" } },
    "claims_in_artifact": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "consent_method": { "type": "string", "enum": ["email", "signature", "verbal_with_followup", "n/a"] },
    "consent_date": { "type": "string", "format": "date" },
    "consent_expires": { "type": "string", "format": "date" },
    "revocable": { "type": "boolean" },
    "decision": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED", "MODIFIED"] },
    "decision_notes": { "type": "string" },
    "decided_by": { "type": "string" },
    "decided_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
