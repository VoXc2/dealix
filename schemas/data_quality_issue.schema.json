{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/data_quality_issue.schema.json",
  "title": "Data Quality Issue",
  "type": "object",
  "required": ["issue_id", "ts", "entity", "dimension", "severity", "status"],
  "properties": {
    "issue_id": { "type": "string" },
    "ts": { "type": "string", "format": "date-time" },
    "entity": { "type": "string" },
    "entity_id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "dimension": { "enum": ["completeness", "accuracy", "consistency", "timeliness", "uniqueness", "validity"] },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "description": { "type": "string" },
    "remediation": { "type": "string" },
    "owner": { "type": "string" },
    "status": { "enum": ["open", "in_progress", "resolved", "accepted"] },
    "detected_at": { "type": "string", "format": "date-time" },
    "resolved_at": { "type": "string", "format": "date-time" }
  }
}
