{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Contact Discovery Record",
  "type": "object",
  "properties": {
    "company_name": {
      "type": "string",
      "minLength": 1
    },
    "channels": {
      "type": "array",
      "items": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Channel",
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "website",
              "email",
              "phone",
              "linkedin",
              "whatsapp_business",
              "contact_form"
            ]
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "enum": [
              "public",
              "founder_provided"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        },
        "required": [
          "type",
          "value",
          "source",
          "confidence"
        ],
        "additionalProperties": false
      },
      "minItems": 0
    },
    "invented": {
      "type": "boolean",
      "const": false
    }
  },
  "required": [
    "company_name",
    "channels",
    "invented"
  ],
  "additionalProperties": false
}
