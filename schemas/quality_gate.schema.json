{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quality Gate Result",
  "type": "object",
  "properties": {
    "gate": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "passed": {
      "type": "boolean"
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    }
  },
  "required": [
    "gate",
    "subject",
    "passed",
    "failures"
  ],
  "additionalProperties": false
}
