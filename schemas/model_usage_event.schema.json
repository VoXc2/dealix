{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/model_usage_event.schema.json",
  "title": "Model Usage Event",
  "type": "object",
  "required": ["event_id", "ts", "task_id", "agent_id", "model_id", "input_tokens", "output_tokens", "cost_usd", "status"],
  "properties": {
    "event_id": { "type": "string" },
    "ts": { "type": "string", "format": "date-time" },
    "task_id": { "type": "string" },
    "agent_id": { "type": "integer" },
    "model_id": { "type": "string" },
    "input_tokens": { "type": "integer" },
    "output_tokens": { "type": "integer" },
    "cost_usd": { "type": "number" },
    "duration_ms": { "type": "integer" },
    "tier": { "enum": ["R1", "R2", "R3"] },
    "client_id": { "type": "string" },
    "project_id": { "type": "string" },
    "status": { "enum": ["ok", "fallback", "failed", "blocked"] },
    "fallback_used": { "type": "boolean" },
    "eval_passed": { "type": "boolean" }
  }
}
