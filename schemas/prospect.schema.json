{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/prospect.schema.json",
  "title": "Dealix Prospect",
  "description": "Company-level prospect. decision_maker is a ROLE, never a personal name (PDPL / no-PII).",
  "type": "object",
  "required": ["prospect_id", "company", "sector", "pain_hypothesis", "score", "status"],
  "properties": {
    "prospect_id": {"type": "string"},
    "company": {"type": "string"},
    "sector": {"type": "string"},
    "website": {"type": "string"},
    "decision_maker_role": {"type": "string"},
    "pain_hypothesis": {"type": "string"},
    "evidence_level": {"type": "string", "enum": ["none", "assumed", "observed", "verified"]},
    "source": {"type": "string"},
    "score": {
      "type": "object",
      "required": ["sector_fit", "buying_signal", "likely_lead_flow", "decision_maker_clarity", "payment_ability", "personalization_signal", "risk_low", "total"],
      "properties": {
        "sector_fit": {"type": "number", "maximum": 20},
        "buying_signal": {"type": "number", "maximum": 20},
        "likely_lead_flow": {"type": "number", "maximum": 15},
        "decision_maker_clarity": {"type": "number", "maximum": 15},
        "payment_ability": {"type": "number", "maximum": 15},
        "personalization_signal": {"type": "number", "maximum": 10},
        "risk_low": {"type": "number", "maximum": 5},
        "total": {"type": "number", "maximum": 100}
      }
    },
    "status": {"type": "string"}
  },
  "additionalProperties": true
}
