{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/content_asset.schema.json",
  "title": "Dealix Content Asset",
  "type": "object",
  "required": ["idea_id", "type", "hook", "evidence_level", "status", "approval_required"],
  "properties": {
    "idea_id": {"type": "string"},
    "type": {"type": "string", "enum": ["founder_insight", "sector_pain", "proof_learning", "case_style"]},
    "sector": {"type": "string"},
    "hook": {"type": "string"},
    "evidence_level": {"type": "string", "enum": ["none", "assumed", "observed", "verified"]},
    "status": {"type": "string", "enum": ["draft", "approved", "published", "archived"]},
    "approval_required": {"type": "boolean"}
  },
  "additionalProperties": true
}
