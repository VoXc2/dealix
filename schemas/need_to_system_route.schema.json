{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Need To System Route",
  "type": "object",
  "properties": {
    "need_id": {
      "type": "string",
      "minLength": 1
    },
    "core_system": {
      "type": "string",
      "enum": [
        "revenue-operating-system",
        "executive-command-os",
        "follow-up-recovery-os",
        "whatsapp-client-os",
        "proposal-proof-os"
      ]
    },
    "specialized_systems": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "required": [
    "need_id",
    "core_system",
    "specialized_systems"
  ],
  "additionalProperties": false
}
