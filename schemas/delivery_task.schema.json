{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/delivery_task.schema.json",
  "title": "Delivery Task",
  "description": "مهمة ضمن delivery pipeline. المهام التي depends_on_inputs=true لا تبدأ قبل استلام المدخلات.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "pipeline_id", "company", "recommended_system", "title", "status", "depends_on_inputs", "owner"],
  "properties": {
    "id": { "type": "string", "pattern": "^DT-[0-9]{3,}$" },
    "pipeline_id": { "type": "string", "pattern": "^DP-[0-9]{3,}$" },
    "company": { "type": "string", "minLength": 1 },
    "recommended_system": {
      "type": "string",
      "enum": ["revenue_os", "executive_command_os", "followup_recovery_os", "whatsapp_client_os", "proposal_proof_os"]
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "status": { "type": "string", "enum": ["todo", "in_progress", "blocked", "done"] },
    "depends_on_inputs": { "type": "boolean" },
    "owner": { "type": "string", "minLength": 1 },
    "due": { "type": "string" },
    "created_at": { "type": "string" }
  }
}
