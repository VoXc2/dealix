{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Specialized Sprint",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name_ar": {
      "type": "string",
      "minLength": 1
    },
    "need_id": {
      "type": "string",
      "minLength": 1
    },
    "core_system": {
      "type": "string",
      "enum": [
        "revenue-operating-system",
        "executive-command-os",
        "follow-up-recovery-os",
        "whatsapp-client-os",
        "proposal-proof-os"
      ]
    },
    "sector": {
      "type": "string",
      "minLength": 1
    },
    "complexity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "duration_days": {
      "type": "integer",
      "minimum": 1
    },
    "starter_price_sar": {
      "type": "integer",
      "minimum": 0
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 3
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 2
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 2
    }
  },
  "required": [
    "id",
    "name_ar",
    "need_id",
    "core_system",
    "sector",
    "deliverables",
    "required_inputs",
    "acceptance_criteria"
  ],
  "additionalProperties": false
}
