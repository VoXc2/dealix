{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/whatsapp_session.schema.json",
  "title": "WhatsApp Session",
  "description": "A post-consent WhatsApp conversation session. Cold/no-consent sessions are forbidden. No raw secrets or full phone numbers are stored here.",
  "type": "object",
  "required": ["id", "created_at", "consent", "locale", "status", "dry_run", "send_enabled"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^WAS-[A-Za-z0-9_-]+$" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "wa_contact_ref": { "type": "string", "description": "Opaque contact reference. NEVER the raw phone number." },
    "phone_masked": { "type": "string", "pattern": "^\\+9665[0-9X]{8}$", "description": "Masked KSA mobile, e.g. +9665XXXX1234. Full number lives only in secure store." },
    "prospect_company": { "type": "string" },
    "locale": { "type": "string", "enum": ["ar", "ar-SA", "en"], "default": "ar" },
    "consent": {
      "type": "object",
      "required": ["consent_basis", "consent_timestamp", "consent_source", "opt_out"],
      "additionalProperties": false,
      "properties": {
        "consent_basis": { "type": "string", "enum": ["explicit_optin", "positive_reply", "booking", "form_submission", "existing_client"], "description": "Cold/none/scraped are NOT allowed." },
        "consent_timestamp": { "type": "string", "format": "date-time" },
        "consent_source": { "type": "string", "description": "e.g. landing_form, email_reply, calendly_booking" },
        "opt_out": { "type": "boolean", "default": false },
        "opt_out_timestamp": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "current_flow": { "type": "string", "description": "flow_id from data/whatsapp/flows.yaml" },
    "current_step": { "type": "string" },
    "assigned_owner": { "type": "string" },
    "linked_assessment_id": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["active", "paused", "awaiting_approval", "handoff", "closed", "opted_out"] },
    "dry_run": { "type": "boolean", "default": true },
    "send_enabled": { "type": "boolean", "default": false },
    "notes": { "type": "string", "description": "No secrets, no API keys, no PII of the client's customers." }
  }
}
