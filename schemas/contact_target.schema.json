{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/contact_target.schema.json",
  "title": "Contact Target Mapping",
  "description": "Maps each Dealix system to the decision-maker role we contact first, with alternates and per-sector overrides. Roles only — never personal names.",
  "type": "object",
  "additionalProperties": false,
  "required": ["system", "primary_roles", "alternate_roles"],
  "properties": {
    "system": {
      "type": "string",
      "enum": [
        "Revenue Operating System",
        "Executive Command OS",
        "Follow-up Recovery OS",
        "WhatsApp Client OS",
        "Proposal & Proof OS"
      ]
    },
    "primary_roles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "alternate_roles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "sector_overrides": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "sector name -> preferred first contact role for that sector."
    },
    "notes": { "type": "string" }
  }
}
