{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/message_performance.schema.json",
  "title": "Message Performance",
  "description": "Performance of one message archetype in one sector, anonymized, evidence-level tagged.",
  "type": "object",
  "required": [
    "archetype",
    "sector",
    "evidence_level",
    "open_rate",
    "reply_rate",
    "positive_reply_rate",
    "sample_size",
    "sample_window",
    "version"
  ],
  "properties": {
    "archetype": {
      "type": "string",
      "enum": [
        "opener",
        "follow_up",
        "reactivation",
        "referral_ask",
        "executive_summary"
      ]
    },
    "sector": {
      "type": "string",
      "enum": [
        "industrial",
        "healthcare",
        "retail",
        "professional_services",
        "real_estate",
        "fnb",
        "logistics",
        "education",
        "government_related"
      ]
    },
    "sub_vertical": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "enum": ["ar", "en", "mixed"],
      "default": "ar"
    },
    "tone": {
      "type": "string",
      "enum": ["formal", "semi_formal", "consultative"],
      "default": "consultative"
    },
    "open_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reply_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "positive_reply_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "meeting_conversion": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Fraction of positive replies that became a meeting."
    },
    "sample_size": {
      "type": "integer",
      "minimum": 0
    },
    "sample_window": {
      "type": "string",
      "pattern": "^[0-9]{4}-Q[1-4]$|^[0-9]{4}-H[1-2]$|^[0-9]{4}-[0-9]{2}$"
    },
    "evidence_level": {
      "type": "string",
      "enum": ["assumption", "observed", "validated", "measured"]
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "subject_pattern_ar": {
      "type": "string",
      "description": "Arabic subject-line pattern (template, no PII)."
    },
    "hook_ar": {
      "type": "string",
      "description": "Arabic first-line hook template."
    },
    "body_structure": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Ordered list of section titles (Arabic-friendly)."
    },
    "cta_options": {
      "type": "array",
      "items": {"type": "string"}
    },
    "length_range_words": {
      "type": "object",
      "properties": {
        "min": {"type": "integer", "minimum": 0},
        "max": {"type": "integer", "minimum": 0}
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
