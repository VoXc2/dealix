{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/company_intelligence_pack.schema.json",
  "title": "Company Intelligence Pack",
  "description": "Per-company acquisition intelligence record. Built only from public company information or founder-provided data. Email stays draft until founder approval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_id",
    "company",
    "sector",
    "recommended_system",
    "best_contact_role",
    "signal",
    "likely_pain",
    "why_this_system",
    "email_subject",
    "email_draft",
    "call_opener",
    "call_questions",
    "next_action",
    "risk_level",
    "evidence_level",
    "approval_required"
  ],
  "properties": {
    "pack_id": { "type": "string", "pattern": "^CIP-[0-9]{3,}$" },
    "company": { "type": "string", "minLength": 2 },
    "website": { "type": "string" },
    "country": { "type": "string" },
    "city": { "type": "string" },
    "sector": { "type": "string" },
    "public_contact_channels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "likely_decision_maker": { "type": "string" },
    "best_contact_role": { "type": "string", "minLength": 2 },
    "signal": { "type": "string", "minLength": 2 },
    "likely_pain": { "type": "string", "minLength": 2 },
    "recommended_system": {
      "type": "string",
      "enum": [
        "Revenue Operating System",
        "Executive Command OS",
        "Follow-up Recovery OS",
        "WhatsApp Client OS",
        "Proposal & Proof OS"
      ]
    },
    "why_this_system": { "type": "string", "minLength": 2 },
    "first_mission": { "type": "string" },
    "proof_angle": { "type": "string" },
    "email_subject": {
      "type": "string",
      "minLength": 2,
      "description": "Must not fake a reply/forward thread.",
      "not": { "pattern": "^(?i)(re:|fwd:|fw:)" }
    },
    "email_draft": { "type": "string", "minLength": 2 },
    "call_opener": { "type": "string", "minLength": 2 },
    "call_questions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "expected_objections": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mini_proposal_angle": { "type": "string" },
    "next_action": { "type": "string", "minLength": 2 },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "evidence_level": {
      "type": "string",
      "enum": ["public_only", "founder_provided", "inferred"]
    },
    "approval_required": {
      "type": "boolean",
      "const": true,
      "description": "Outreach is always a draft until the founder approves it."
    },
    "do_not_contact": { "type": "boolean", "default": false },
    "created_at": { "type": "string" }
  }
}
