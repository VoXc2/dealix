{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Company Intelligence Pack",
  "type": "object",
  "required": [
    "company_name",
    "sector",
    "recommended_system"
  ],
  "properties": {
    "company_name": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "recommended_system": {
      "type": "string"
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "needs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
