  "type": "object",
  "properties": {
    "sprint_id": {
      "type": "string",
      "minLength": 1
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "required": [
    "sprint_id",
    "criteria",
    "owner",
    "required_inputs"
  ],
  "additionalProperties": false
}
