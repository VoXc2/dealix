{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/call_brief.schema.json",
  "title": "Call Brief",
  "description": "Everything a human caller needs to run a discovery call. Briefs are for human callers only; automated calling is never enabled.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "brief_id",
    "company",
    "contact_role",
    "recommended_system",
    "likely_pain",
    "call_objective",
    "opening_line",
    "discovery_questions",
    "next_step",
    "caller_type",
    "automated_calling"
  ],
  "properties": {
    "brief_id": { "type": "string", "pattern": "^CB-[0-9]{3,}$" },
    "company": { "type": "string", "minLength": 2 },
    "contact_role": { "type": "string", "minLength": 2 },
    "recommended_system": {
      "type": "string",
      "enum": [
        "Revenue Operating System",
        "Executive Command OS",
        "Follow-up Recovery OS",
        "WhatsApp Client OS",
        "Proposal & Proof OS"
      ]
    },
    "likely_pain": { "type": "string", "minLength": 2 },
    "email_sent_summary": { "type": "string" },
    "call_objective": { "type": "string", "minLength": 2 },
    "opening_line": { "type": "string", "minLength": 2 },
    "discovery_questions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "expected_objection": { "type": "string" },
    "best_response": { "type": "string" },
    "next_step": { "type": "string", "minLength": 2 },
    "caller_type": { "type": "string", "const": "human" },
    "automated_calling": { "type": "boolean", "const": false },
    "created_at": { "type": "string" }
  }
}
