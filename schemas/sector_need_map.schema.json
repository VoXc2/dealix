{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sector Need Map",
  "type": "object",
  "properties": {
    "sector": {
      "type": "string",
      "minLength": 1
    },
    "sector_name_ar": {
      "type": "string",
      "minLength": 1
    },
    "needs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "required": [
    "sector",
    "sector_name_ar",
    "needs"
  ],
  "additionalProperties": false
}
