{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/client_need_card.schema.json",
  "title": "Client Need Card",
  "description": "Translates a company's situation into a concrete need, the system that answers it, and the inputs required to start.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "card_id",
    "company",
    "sector",
    "recommended_system",
    "pain_hypothesis",
    "success_metric",
    "required_inputs",
    "decision_maker_target",
    "evidence_level",
    "next_action"
  ],
  "properties": {
    "card_id": { "type": "string", "pattern": "^CNC-[0-9]{3,}$" },
    "company": { "type": "string", "minLength": 2 },
    "sector": { "type": "string" },
    "recommended_system": {
      "type": "string",
      "enum": [
        "Revenue Operating System",
        "Executive Command OS",
        "Follow-up Recovery OS",
        "WhatsApp Client OS",
        "Proposal & Proof OS"
      ]
    },
    "current_state": { "type": "string" },
    "pain_hypothesis": { "type": "string", "minLength": 2 },
    "desired_outcome": { "type": "string" },
    "success_metric": { "type": "string", "minLength": 2 },
    "required_inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "decision_maker_target": { "type": "string", "minLength": 2 },
    "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
    "evidence_level": {
      "type": "string",
      "enum": ["public_only", "founder_provided", "inferred"]
    },
    "next_action": { "type": "string", "minLength": 2 },
    "created_at": { "type": "string" }
  }
}
