{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Follow-up Sequence",
  "type": "object",
  "required": [
    "sequence_id",
    "system",
    "steps"
  ],
  "properties": {
    "sequence_id": {
      "type": "string"
    },
    "system": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "day",
          "channel"
        ],
        "properties": {
          "day": {
            "type": "integer",
            "minimum": 0
          },
          "channel": {
            "type": "string"
          },
          "message_ar": {
            "type": "string"
          }
        }
      }
    }
  }
}
