{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/follow_up_sequence.schema.json",
  "title": "Follow-up Sequence",
  "description": "تسلسل متابعة مرتبط بإيميل. كل الخطوات مسودات؛ تتوقف عند رد/إلغاء/تحويل. cadence افتراضي [3,7,14] أيام.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "company", "recommended_system", "related_email_subject", "status", "steps", "rules"],
  "properties": {
    "id": { "type": "string", "pattern": "^FUS-[0-9]{3,}$" },
    "company": { "type": "string", "minLength": 1 },
    "recommended_system": {
      "type": "string",
      "enum": ["revenue_os", "executive_command_os", "followup_recovery_os", "whatsapp_client_os", "proposal_proof_os"]
    },
    "related_email_subject": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["scheduled", "in_progress", "stopped", "completed"] },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "day_offset", "channel", "subject", "message", "stop_conditions"],
        "properties": {
          "sequence": { "type": "integer", "minimum": 1 },
          "day_offset": { "type": "integer", "minimum": 0 },
          "channel": { "type": "string", "enum": ["email"] },
          "subject": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "stop_conditions": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["follow_up_sequence", "max_followups", "stop_conditions"],
      "properties": {
        "follow_up_sequence": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
        "max_followups": { "type": "integer", "minimum": 1, "maximum": 5 },
        "stop_conditions": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    }
  }
}
