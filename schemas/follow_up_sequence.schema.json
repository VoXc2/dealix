{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix/schemas/follow_up_sequence.schema.json",
  "title": "Follow-up Sequence",
  "description": "An ordered set of follow-up message drafts for a given system and lead status. Drafts only; never auto-sent.",
  "type": "object",
  "required": ["sequence_id", "recommended_system", "steps"],
  "properties": {
    "sequence_id": { "type": "string" },
    "recommended_system": {
      "type": "string",
      "enum": [
        "revenue-operating-system",
        "executive-command-os",
        "follow-up-recovery-os",
        "whatsapp-client-os",
        "proposal-proof-os"
      ]
    },
    "lead_status": { "type": "string", "description": "e.g. no_reply, opened_no_reply, interested, gone_quiet" },
    "channel": { "type": "string", "enum": ["email", "human_call_note"], "description": "No cold WhatsApp or automated channels." },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order", "wait_days", "message_draft"],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "wait_days": { "type": "integer", "minimum": 0 },
          "subject": { "type": "string" },
          "message_draft": { "type": "string" },
          "goal": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "stop_conditions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
