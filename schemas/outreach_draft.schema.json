{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/outreach_draft.schema.json",
  "title": "Outreach Draft",
  "description": "A drafted outbound message. Drafts are generated by AI but NEVER sent without explicit founder approval. All sends default to dry_run=true.",
  "type": "object",
  "required": ["id", "type", "company", "channel", "risk", "requires_approval", "approved", "dry_run"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^(DRAFT|APP)-[0-9]{3,}$" },
    "type": { "type": "string", "enum": ["outreach_message", "follow_up", "reply", "proposal_intro", "partner_intro"] },
    "company": { "type": "string", "minLength": 1 },
    "channel": { "type": "string", "enum": ["email", "whatsapp_after_consent", "linkedin_manual"] },
    "draft_subject": { "type": "string" },
    "draft_body": { "type": "string" },
    "evidence_level": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4", "L5"] },
    "offer_mapping": { "type": "string", "description": "Must map to an offer in the product catalog." },
    "personalization": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
    "has_unsubscribe": { "type": "boolean" },
    "risk": { "type": "string", "enum": ["low", "medium", "high"] },
    "requires_approval": { "const": true },
    "approved": { "type": "boolean" },
    "dry_run": { "const": true },
    "reviewed_by": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "approved_at": { "type": ["string", "null"] }
  }
}
