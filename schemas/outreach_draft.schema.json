{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/outreach_draft.schema.json",
  "title": "Dealix Outreach Draft",
  "description": "A draft is production-only. Real send requires approval + deliverability verdict >= LIMITED_SEND_READY + not suppressed.",
  "type": "object",
  "required": ["draft_id", "draft_type", "prospect_id", "company", "sector", "pain_hypothesis", "offer_match", "personalization_score", "evidence_level", "risk_level", "subject", "body", "opt_out", "approval_status", "send_status"],
  "properties": {
    "draft_id": {"type": "string"},
    "draft_type": {"type": "string", "enum": ["first_touch", "follow_up_1", "follow_up_2", "proposal_intro", "close_loop"]},
    "prospect_id": {"type": "string"},
    "company": {"type": "string"},
    "sector": {"type": "string"},
    "pain_hypothesis": {"type": "string", "enum": ["lead_leakage", "follow_up_chaos", "crm_data_disorder", "proposal_delay", "weak_reporting", "sales_team_inconsistency", "support_overload", "no_proof_case_study_system", "slow_onboarding", "weak_renewal_upsell"]},
    "offer_match": {"type": "string", "pattern": "^DLX-L[0-6]$"},
    "personalization_score": {"type": "string", "enum": ["P0", "P1", "P2", "P3", "P4"]},
    "evidence_level": {"type": "string", "enum": ["none", "assumed", "observed", "verified"]},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
    "subject": {"type": "string"},
    "body": {"type": "string"},
    "opt_out": {"type": "object", "required": ["included"], "properties": {"included": {"type": "boolean"}, "method": {"type": "string"}, "text": {"type": "string"}}},
    "recipient_domain": {"type": "string"},
    "approval_status": {"type": "string", "enum": ["pending", "approved", "rejected", "needs_revision"]},
    "send_status": {"type": "string", "enum": ["not_sent", "queued_plan", "approved_for_send", "sent", "suppressed", "bounced"]},
    "created_at": {"type": "string"}
  },
  "additionalProperties": true
}
