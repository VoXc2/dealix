{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/payment_handoff.schema.json",
  "title": "Payment Handoff",
  "description": "Prepares a payment step for founder approval. No payment link is sent without approval. send_enabled defaults to false.",
  "type": "object",
  "required": ["id", "created_at", "proposal_id", "company", "amount_sar", "payment_provider", "approval_required", "approved", "status", "risk_level", "dry_run", "send_enabled"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^PAY-[A-Za-z0-9_-]+$" },
    "created_at": { "type": "string", "format": "date-time" },
    "proposal_id": { "type": "string", "description": "Links to an approved proposal (founder_approved=true)." },
    "company": { "type": "string" },
    "amount_sar": { "type": "number", "minimum": 0 },
    "payment_provider": { "type": "string", "enum": ["bank_transfer", "moyasar", "hyperpay", "stc_pay", "tap", "other"] },
    "payment_link_ref": { "type": ["string", "null"], "pattern": "^portal://[A-Za-z0-9_/-]+$", "description": "Reference to a link created in the portal. NEVER a live payable URL in data/logs, and NEVER auto-sent." },
    "approval_required": { "type": "boolean", "const": true },
    "approved": { "type": "boolean", "default": false },
    "approved_by": { "type": ["string", "null"] },
    "approved_at": { "type": ["string", "null"], "format": "date-time" },
    "status": { "type": "string", "enum": ["draft", "pending_approval", "approved", "sent_manually", "paid", "rejected", "cancelled"] },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"], "default": "high" },
    "dry_run": { "type": "boolean", "default": true },
    "send_enabled": { "type": "boolean", "default": false },
    "notes": { "type": "string", "description": "No secrets, no full card/account numbers." }
  }
}
