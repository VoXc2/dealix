{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Weekly Value Report",
  "type": "object",
  "properties": {
    "client": {
      "type": "string",
      "minLength": 1
    },
    "week_of": {
      "type": "string",
      "minLength": 1
    },
    "system": {
      "type": "string",
      "enum": [
        "revenue-operating-system",
        "executive-command-os",
        "follow-up-recovery-os",
        "whatsapp-client-os",
        "proposal-proof-os"
      ]
    },
    "metrics": {
      "type": "array",
      "items": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Metric",
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "name",
          "value"
        ],
        "additionalProperties": false
      },
      "minItems": 1
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "required": [
    "client",
    "week_of",
    "system",
    "metrics",
    "next_actions"
  ],
  "additionalProperties": false
}
