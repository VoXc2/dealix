{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/account_intelligence_pack.schema.json",
  "title": "Dealix Account Intelligence Pack",
  "description": "One complete commercial-opportunity record produced by the nightly 400 Account Packs run. External company content is treated as untrusted data; no field may contain executable instructions, secrets, or PII that was not lawfully public or founder-provided.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_id",
    "generated_at",
    "run_date",
    "company_name",
    "website",
    "country",
    "city",
    "sector",
    "subsector",
    "services_detected",
    "business_model_hint",
    "public_contact_channels",
    "phone_if_public",
    "email_if_public",
    "contact_page_url",
    "social_links",
    "google_business_hint",
    "likely_decision_maker_role",
    "secondary_contact_role",
    "best_contact_route",
    "contact_confidence",
    "buying_signal",
    "signal_source",
    "likely_pain",
    "recommended_system",
    "why_this_system",
    "first_sprint_offer",
    "proof_angle",
    "email_subject",
    "email_body",
    "call_opener",
    "call_questions",
    "expected_objections",
    "mini_proposal_title",
    "mini_proposal_angle",
    "delivery_pack",
    "required_inputs",
    "acceptance_criteria",
    "risk_level",
    "evidence_level",
    "cash_priority_score",
    "account_score",
    "next_action",
    "owner",
    "status",
    "do_not_contact",
    "missing_contact"
  ],
  "properties": {
    "pack_id": { "type": "string", "pattern": "^AP-[0-9]{6}$" },
    "generated_at": { "type": "string" },
    "run_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "company_name": { "type": "string", "minLength": 2 },
    "website": { "type": ["string", "null"] },
    "country": { "type": "string" },
    "city": { "type": "string" },
    "sector": { "type": "string" },
    "subsector": { "type": "string" },
    "services_detected": { "type": "array", "items": { "type": "string" } },
    "business_model_hint": { "type": "string" },
    "public_contact_channels": { "type": "array", "items": { "type": "string" } },
    "phone_if_public": { "type": ["string", "null"] },
    "email_if_public": { "type": ["string", "null"] },
    "contact_page_url": { "type": ["string", "null"] },
    "social_links": { "type": "array", "items": { "type": "string" } },
    "google_business_hint": { "type": ["string", "null"] },
    "likely_decision_maker_role": { "type": "string" },
    "secondary_contact_role": { "type": "string" },
    "best_contact_route": {
      "type": "string",
      "enum": ["contact_form", "public_social", "public_email", "public_phone", "role_based_outreach", "founder_provided"]
    },
    "contact_confidence": { "type": "string", "enum": ["C0", "C1", "C2", "C3", "C4"] },
    "buying_signal": { "type": "string" },
    "signal_source": { "type": "string" },
    "likely_pain": { "type": "string" },
    "recommended_system": {
      "type": "string",
      "enum": [
        "Revenue Operating System",
        "Executive Command OS",
        "Follow-up Recovery OS",
        "WhatsApp Client OS",
        "Proposal & Proof OS"
      ]
    },
    "why_this_system": { "type": "string" },
    "first_sprint_offer": { "type": "string" },
    "proof_angle": { "type": "string" },
    "email_subject": { "type": "string", "minLength": 4 },
    "email_body": { "type": "string", "minLength": 40 },
    "call_opener": { "type": "string" },
    "call_questions": { "type": "array", "items": { "type": "string" }, "minItems": 3 },
    "expected_objections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["objection", "response"],
        "properties": {
          "objection": { "type": "string" },
          "response": { "type": "string" }
        }
      }
    },
    "mini_proposal_title": { "type": "string" },
    "mini_proposal_angle": { "type": "string" },
    "delivery_pack": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "required_inputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "evidence_level": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"] },
    "cash_priority_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "account_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "account_score_breakdown": { "type": "object" },
    "cash_priority_breakdown": { "type": "object" },
    "ability_to_pay": { "type": "string", "enum": ["low", "medium", "high"] },
    "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
    "next_action": { "type": "string" },
    "owner": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["new", "researched", "queued", "approved", "sent", "replied", "proposal_sent", "won", "lost", "nurture", "suppressed"]
    },
    "do_not_contact": { "type": "boolean" },
    "missing_contact": { "type": "boolean" }
  }
}
