{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealix.sa/schemas/account_intelligence_pack.schema.json",
  "title": "Account Intelligence Pack",
  "description": "A complete, single-company sales file produced by the Dealix Account Intelligence-to-Revenue Factory. Replaces the old single-email draft. Every external fact must carry an evidence level; nothing is asserted as a guarantee.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "company_name",
    "country",
    "city",
    "sector",
    "public_contact_channels",
    "likely_decision_maker_role",
    "best_contact_route",
    "likely_pain",
    "recommended_system",
    "why_this_system",
    "first_sprint_offer",
    "email_subject",
    "email_body",
    "mini_proposal_title",
    "required_inputs",
    "risk_level",
    "evidence_level",
    "next_action",
    "owner",
    "status"
  ],
  "properties": {
    "company_name": { "type": "string", "minLength": 1 },
    "website": {
      "type": ["string", "null"],
      "description": "Public website if found, else null. Never invented."
    },
    "country": { "type": "string", "minLength": 1 },
    "city": { "type": "string", "minLength": 1 },
    "sector": { "type": "string", "minLength": 1 },
    "subsector": { "type": ["string", "null"] },
    "services_detected": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Services inferred only from public sources (L1+)."
    },
    "business_model_hint": { "type": ["string", "null"] },
    "public_contact_channels": {
      "type": "array",
      "description": "References into contact_channels data. May be empty when no public channel exists (handled gracefully).",
      "items": { "type": "string" }
    },
    "phone_if_public": {
      "type": ["string", "null"],
      "description": "Only set when a public phone exists at evidence L2+. Never guessed."
    },
    "email_if_public": {
      "type": ["string", "null"],
      "description": "Only public generic/role mailbox (info@, sales@). Never a guessed personal address."
    },
    "contact_page_url": { "type": ["string", "null"] },
    "social_links": {
      "type": "array",
      "items": { "type": "string" }
    },
    "google_business_hint": { "type": ["string", "null"] },
    "likely_decision_maker_role": {
      "type": "string",
      "description": "A role title, never an invented personal name. Must be valid for recommended_system per the targeting matrix."
    },
    "secondary_contact_role": { "type": ["string", "null"] },
    "best_contact_route": {
      "type": "string",
      "enum": ["email", "contact_form", "phone", "linkedin_public", "social_dm", "website_only", "none_found"]
    },
    "buying_signal": { "type": ["string", "null"] },
    "signal_source": {
      "type": ["string", "null"],
      "description": "Public URL or source label backing the buying_signal."
    },
    "likely_pain": { "type": "string", "minLength": 1 },
    "recommended_system": {
      "type": "string",
      "enum": [
        "revenue_os",
        "executive_command_os",
        "followup_recovery_os",
        "whatsapp_client_os",
        "proposal_proof_os"
      ]
    },
    "why_this_system": { "type": "string", "minLength": 1 },
    "first_sprint_offer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "starter_price_sar", "deliverables"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "starter_price_sar": { "type": "number", "minimum": 0 },
        "timeline_days": { "type": ["integer", "null"], "minimum": 1 },
        "deliverables": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "proof_angle": { "type": ["string", "null"] },
    "email_subject": {
      "type": "string",
      "minLength": 1,
      "description": "No misleading Re:/Fwd: prefixes."
    },
    "email_body": { "type": "string", "minLength": 1 },
    "call_opener": { "type": ["string", "null"] },
    "call_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expected_objections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["objection", "response"],
        "properties": {
          "objection": { "type": "string" },
          "response": { "type": "string" }
        }
      }
    },
    "mini_proposal_title": { "type": "string", "minLength": 1 },
    "mini_proposal_angle": { "type": ["string", "null"] },
    "delivery_pack": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "evidence_level": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"]
    },
    "contact_confidence": {
      "type": "string",
      "enum": ["CC0", "CC1", "CC2", "CC3"]
    },
    "score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100,
      "description": "Top-100 ranking score, populated by the scoring model."
    },
    "next_action": {
      "type": "string",
      "enum": [
        "research_more",
        "find_contact",
        "build_need_card",
        "write_draft",
        "quality_review",
        "founder_approve",
        "send",
        "schedule_call",
        "log_call",
        "send_mini_proposal",
        "follow_up",
        "start_delivery",
        "hold",
        "drop"
      ]
    },
    "owner": {
      "type": "string",
      "enum": ["founder", "caller", "agent", "unassigned"]
    },
    "status": {
      "type": "string",
      "enum": [
        "researched",
        "contact_found",
        "need_card_ready",
        "draft_ready",
        "quality_passed",
        "top_100",
        "approved",
        "sent",
        "call_due",
        "called",
        "interested",
        "mini_proposal_ready",
        "proposal_sent",
        "won",
        "delivery_started",
        "active",
        "renewal_candidate",
        "lost",
        "do_not_contact"
      ]
    },
    "account_id": { "type": "string" },
    "run_date": { "type": "string" }
  }
}
