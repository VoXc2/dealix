{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mini Proposal",
  "type": "object",
  "required": [
    "proposal_id",
    "company_name",
    "title",
    "price",
    "currency",
    "scope",
    "required_inputs",
    "acceptance_criteria",
    "approval_required",
    "status"
  ],
  "properties": {
    "proposal_id": {
      "type": "string"
    },
    "company_name": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "price": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_required": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "approved",
        "sent",
        "won",
        "lost"
      ]
    }
  }
}
