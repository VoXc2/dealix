{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/mini_proposal.schema.json",
  "title": "Dealix Mini Proposal",
  "description": "One-page mini proposal generated from an account pack. It stays a draft until founder approval (approval_required is always true) and must never contain guaranteed-result claims.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_id",
    "pack_id",
    "company_name",
    "title",
    "recommended_system",
    "public_signal",
    "likely_pain",
    "why_this_system",
    "first_sprint",
    "deliverables",
    "timeline",
    "starter_price_sar",
    "required_inputs",
    "expected_first_proof",
    "risks_assumptions",
    "next_step",
    "approval_required",
    "status",
    "generated_at"
  ],
  "properties": {
    "proposal_id": { "type": "string", "pattern": "^MP-[0-9]{6}$" },
    "pack_id": { "type": "string", "pattern": "^AP-[0-9]{6}$" },
    "company_name": { "type": "string" },
    "title": { "type": "string" },
    "recommended_system": { "type": "string" },
    "public_signal": { "type": "string" },
    "likely_pain": { "type": "string" },
    "why_this_system": { "type": "string" },
    "first_sprint": { "type": "string" },
    "deliverables": { "type": "array", "items": { "type": "string" }, "minItems": 3 },
    "timeline": { "type": "string" },
    "starter_price_sar": { "type": "integer", "minimum": 1 },
    "required_inputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "expected_first_proof": { "type": "string" },
    "risks_assumptions": { "type": "array", "items": { "type": "string" } },
    "next_step": { "type": "string" },
    "approval_required": { "type": "boolean", "const": true },
    "status": { "type": "string", "enum": ["draft", "approval_queue", "approved", "sent", "rejected"] },
    "generated_at": { "type": "string" }
  }
}
