{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mini Proposal",
  "type": "object",
  "properties": {
    "company_name": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "core_system": {
      "type": "string",
      "enum": [
        "revenue-operating-system",
        "executive-command-os",
        "follow-up-recovery-os",
        "whatsapp-client-os",
        "proposal-proof-os"
      ]
    },
    "sprint_id": {
      "type": "string",
      "minLength": 1
    },
    "starter_price_sar": {
      "type": "integer",
      "minimum": 1
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 2
    },
    "timeline_days": {
      "type": "integer",
      "minimum": 1
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "open_scope": {
      "type": "boolean",
      "const": false
    },
    "approval_required": {
      "type": "boolean",
      "const": true
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "approved",
        "sent",
        "won",
        "lost"
      ]
    }
  },
  "required": [
    "company_name",
    "title",
    "core_system",
    "sprint_id",
    "starter_price_sar",
    "deliverables",
    "timeline_days",
    "required_inputs",
    "open_scope",
    "approval_required"
  ],
  "additionalProperties": false
}
