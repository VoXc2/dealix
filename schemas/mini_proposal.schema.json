{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealix.sa/schemas/mini_proposal.schema.json",
  "title": "Mini Proposal",
  "description": "A one-page proposal generated for an interested account. Must always carry a starter price and require human approval before it is sent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "company",
    "recommended_system",
    "why_this_system",
    "likely_pain",
    "first_sprint",
    "deliverables",
    "timeline_days",
    "starter_price_sar",
    "required_inputs",
    "expected_first_proof",
    "next_step",
    "approval_required"
  ],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "company": { "type": "string", "minLength": 1 },
    "recommended_system": {
      "type": "string",
      "enum": [
        "revenue_os",
        "executive_command_os",
        "followup_recovery_os",
        "whatsapp_client_os",
        "proposal_proof_os"
      ]
    },
    "why_this_system": { "type": "string", "minLength": 1 },
    "public_signal": { "type": ["string", "null"] },
    "likely_pain": { "type": "string", "minLength": 1 },
    "first_sprint": { "type": "string", "minLength": 1 },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "timeline_days": { "type": "integer", "minimum": 1 },
    "starter_price_sar": { "type": "number", "minimum": 1 },
    "required_inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "expected_first_proof": { "type": "string", "minLength": 1 },
    "next_step": { "type": "string", "minLength": 1 },
    "approval_required": {
      "type": "boolean",
      "const": true,
      "description": "Always true. A mini proposal is a draft until the founder approves it."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "sent", "accepted", "declined"]
    }
  }
}
