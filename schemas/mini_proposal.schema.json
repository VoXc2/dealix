{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/mini_proposal.schema.json",
  "title": "Mini Proposal",
  "description": "One-page sprint proposal for a single company. Requires founder approval before it is sent. No guaranteed-revenue claims allowed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_id",
    "title",
    "company",
    "recommended_system",
    "why_this_system",
    "current_likely_pain",
    "first_sprint",
    "deliverables",
    "timeline",
    "starter_price",
    "starter_price_sar",
    "required_inputs",
    "expected_first_proof",
    "next_step",
    "approval_required"
  ],
  "properties": {
    "proposal_id": { "type": "string", "pattern": "^MP-[0-9]{3,}$" },
    "title": { "type": "string", "minLength": 2 },
    "company": { "type": "string", "minLength": 2 },
    "recommended_system": {
      "type": "string",
      "enum": [
        "Revenue Operating System",
        "Executive Command OS",
        "Follow-up Recovery OS",
        "WhatsApp Client OS",
        "Proposal & Proof OS"
      ]
    },
    "why_this_system": { "type": "string", "minLength": 2 },
    "current_likely_pain": { "type": "string", "minLength": 2 },
    "first_sprint": { "type": "string", "minLength": 2 },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "timeline": { "type": "string", "minLength": 2 },
    "starter_price": {
      "type": "string",
      "minLength": 2,
      "description": "Human-readable starter price label, e.g. 'تبدأ من 3,500 ريال'."
    },
    "starter_price_sar": { "type": "number", "exclusiveMinimum": 0 },
    "required_inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "expected_first_proof": { "type": "string", "minLength": 2 },
    "next_step": { "type": "string", "minLength": 2 },
    "approval_required": {
      "type": "boolean",
      "const": true,
      "description": "Mini proposal cannot be sent before founder approval."
    },
    "created_at": { "type": "string" }
  }
}
