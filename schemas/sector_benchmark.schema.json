{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/sector_benchmark.schema.json",
  "title": "Sector Benchmark",
  "description": "Saudi-sector benchmark row for Dealix GTM funnel, with evidence_level and version tags. Anonymized: no PII, no real client names.",
  "type": "object",
  "required": [
    "sector",
    "period",
    "sample_size",
    "evidence_level",
    "reply_rate",
    "positive_reply_rate",
    "meeting_rate",
    "proposal_rate",
    "close_rate",
    "deal_size_band",
    "common_objections",
    "best_cta",
    "best_offer",
    "delivery_complexity",
    "renewal_probability_band",
    "version"
  ],
  "properties": {
    "sector": {
      "type": "string",
      "enum": [
        "industrial",
        "healthcare",
        "retail",
        "professional_services",
        "real_estate",
        "fnb",
        "logistics",
        "education",
        "government_related"
      ],
      "description": "Saudi sector bucket (sector_related_sub_vertical may live in notes)."
    },
    "sub_vertical": {
      "type": "string",
      "description": "Optional sub-vertical (e.g. dental_clinics, real_estate_brokers, logistics_3pl)."
    },
    "period": {
      "type": "string",
      "pattern": "^[0-9]{4}-Q[1-4]$|^[0-9]{4}-H[1-2]$|^[0-9]{4}-[0-9]{2}$",
      "description": "Aggregation window: 2026-Q1, 2026-H1, or 2026-05."
    },
    "sample_size": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of anonymized opportunities in the period."
    },
    "evidence_level": {
      "type": "string",
      "enum": ["assumption", "observed", "validated", "measured"],
      "description": "How this row's numbers are justified. assumption = hypothesis, observed = internal record, validated = cross-checked, measured = statistically significant."
    },
    "reply_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Fraction of contacted leads that replied (0-1)."
    },
    "positive_reply_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Fraction of replies that were positive (interested / open to call)."
    },
    "meeting_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Fraction of positive replies that converted to a meeting."
    },
    "proposal_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Fraction of meetings that converted to a proposal sent."
    },
    "close_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Fraction of proposals that converted to a won deal."
    },
    "deal_size_band": {
      "type": "object",
      "required": ["min_sar", "max_sar"],
      "properties": {
        "min_sar": {"type": "number", "minimum": 0},
        "max_sar": {"type": "number", "minimum": 0},
        "typical_sar": {"type": "number", "minimum": 0}
      }
    },
    "common_objections": {
      "type": "array",
      "minItems": 0,
      "maxItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "too_expensive",
          "no_time",
          "we_already_have_vendor",
          "need_to_think",
          "send_proposal",
          "not_the_right_time",
          "not_relevant",
          "send_to_procurement",
          "we_tried_ai",
          "privacy_concerns",
          "need_to_check_with_partner",
          "no_problem",
          "no_budget",
          "internal_team"
        ]
      }
    },
    "best_cta": {
      "type": "string",
      "enum": [
        "diagnostic_offer",
        "short_audit_call",
        "roi_calculator",
        "case_study_link",
        "sample_workflow",
        "no_cta_nurture",
        "pilot_offer",
        "executive_summary"
      ]
    },
    "best_offer": {
      "type": "string",
      "enum": [
        "revenue_leakage_diagnostic",
        "follow_up_recovery_workflow",
        "ai_revenue_ops_starter",
        "full_revenue_os",
        "monthly_optimization",
        "custom_company_os"
      ]
    },
    "delivery_complexity": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "renewal_probability_band": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": {"type": "number", "minimum": 0, "maximum": 1},
        "max": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$",
      "description": "Benchmark version. Bump minor when source data shifts > 10%."
    },
    "notes": {
      "type": "string",
      "description": "Optional context. Must NOT contain PII, real client names, or specific contract values."
    },
    "owner": {
      "type": "string",
      "description": "Role accountable for this row (e.g. sales_lead, founder, csm_lead)."
    }
  },
  "additionalProperties": false
}
