# Dealix Watchdog — Railway cron job (runs, checks health, exits)
# Minimal image: only needs urllib (stdlib), no extra deps.

FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    APP_ENV=production

RUN groupadd --gid 1000 app \
    && useradd --uid 1000 --gid app --shell /bin/bash --create-home app

WORKDIR /app
COPY --chown=app:app scripts/railway_watchdog.py scripts/railway_watchdog.py

USER app

CMD ["python", "scripts/railway_watchdog.py"]
