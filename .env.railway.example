# ═══════════════════════════════════════════════════════════════
# Dealix — Railway Environment Variables Template
# Copy to Railway dashboard → Service → Variables
# DO NOT commit this file with real values
# ═══════════════════════════════════════════════════════════════

# ── Core App ─────────────────────────────────────────────────
APP_ENV=production
ENVIRONMENT=production
APP_URL=https://api.dealix.me
BASE_URL=https://api.dealix.me
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# ── Dockerfile path (Railway auto-detects) ───────────────────
RAILWAY_DOCKERFILE_PATH=Dockerfile

# ── Database (Railway injects via reference variable) ────────
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── Secrets (generate with: python -c "import secrets; print(secrets.token_hex(32))") ──
APP_SECRET_KEY=<generate-64-char-hex>
JWT_SECRET_KEY=<generate-64-char-hex>

# ── API Keys (comma-separated) ──────────────────────────────
API_KEYS=<your-api-key-1>,<your-api-key-2>
ADMIN_API_KEYS=<your-admin-key>
DEALIX_ADMIN_API_KEY=<your-dealix-admin-key>

# ── CORS (comma-separated origins) ──────────────────────────
CORS_ORIGINS=https://dealix.me,https://app.dealix.me,https://api.dealix.me

# ── LLM Providers (optional — set the ones you use) ─────────
# ANTHROPIC_API_KEY=
# Hermes Agents (falls back to ANTHROPIC_API_KEY if HERMES_API_KEY not set)
# HERMES_API_KEY=
# HERMES_MODEL=claude-opus-4-8
# HERMES_COST_BUDGET_USD=5.0
# MINIMAX_API_KEY=
# MINIMAX_MODEL=MiniMax-Text-01
# MINIMAX_OUTREACH_MAX_PER_DAY=20
# OPENAI_API_KEY=
# GROQ_API_KEY=
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=

# ── Email (optional) ────────────────────────────────────────
# RESEND_API_KEY=
# DEALIX_FOUNDER_EMAIL=sami.assiri11@gmail.com

# ── WhatsApp (optional — production only after legal) ───────
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ALLOW_LIVE_SEND=false

# ── HubSpot (optional) ─────────────────────────────────────
# HUBSPOT_ACCESS_TOKEN=
# HUBSPOT_PORTAL_ID=

# ── Observability (optional) ────────────────────────────────
# SENTRY_DSN=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# ── ZATCA E-Invoice (optional) ──────────────────────────────
# ZATCA_CSID=
# ZATCA_SECRET=
# ZATCA_SANDBOX=true

# ── Worker-specific (founder-os-worker service only) ────────
# FOUNDER_OS_INTERVAL_SECONDS=900
# AGENT_APPROVAL_MODE=required
# AUTO_SEND_ENABLED=false
# EXTERNAL_OUTREACH_ENABLED=false

# ── Watchdog-specific (dealix-watchdog cron only) ───────────
# DEALIX_API_URL=https://api.dealix.me
# DEALIX_HEALTH_PATH=/healthz
