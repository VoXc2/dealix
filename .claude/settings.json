{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(ruff check:*)",
      "Bash(black --check:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(make lint)",
      "Bash(make test:*)",
      "Bash(make test-unit)",
      "Bash(make format)",
      "Bash(make type-check)",
      "Bash(make help)",
      "Bash(alembic current)",
      "Bash(alembic history:*)",
      "Bash(alembic heads)",
      "Bash(pre-commit run:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(alembic upgrade:*)",
      "Bash(alembic downgrade:*)",
      "Bash(docker compose down:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
