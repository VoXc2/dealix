    "shimmer": { "0%": { "backgroundPosition": "-1000px 0" }, "100%": { "backgroundPosition": "1000px 0" } },
    "spin": { "to": { "transform": "rotate(360deg)" } },
    "scaleIn": { "from": { "opacity": 0, "transform": "scale(0.95)" }, "to": { "opacity": 1, "transform": "scale(1)" } }
